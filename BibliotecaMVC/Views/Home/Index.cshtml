@model IEnumerable<BibliotecaMVC.Models.Libro>

<h2>Lista de Libros</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (User.IsInRole("Admin"))
{
    <a class="btn btn-success" href="/Libros/Create">Agregar Libro</a>
    <a class="btn btn-secondary" href="/Autores/Create">Agregar Autor</a>
}
@if (User.Identity?.IsAuthenticated ?? false)
{
    <a class="btn btn-warning" asp-controller="Prestamos" asp-action="Index">
        Préstamos Activos
    </a>
}

<br />
<br />

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Título</th>
            <th>Autor</th>
            <th>Stock</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var libro in Model)
        {
            <tr>
                <td>@libro.Titulo</td>
                <td>@libro.Autor?.Nombre</td>
                <td>@libro.Stock</td>
                <td>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    @if (libro.Stock > 0)
                    {
                         <a class="btn btn-info btn-sm"
                             asp-controller="Prestamos"
                             asp-action="ConfirmarPrestamo"
                             asp-route-id="@libro.Id">
                             Prestar
                         </a>
                    }
                    else
                    {
                        <span class="text-danger">Sin stock</span>
                    }
                }
                </td>
            </tr>
        }
    </tbody>
</table>
