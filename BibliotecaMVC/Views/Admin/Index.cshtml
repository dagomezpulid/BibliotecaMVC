@model BibliotecaMVC.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Panel de Control";
}


<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">📊 Panel de Control</h2>
    <span class="text-muted">Vista General de Biblioteca</span>
</div>

<!-- ESTADÍSTICAS PRINCIPALES (TARJETAS NAVEGABLES) -->
<div class="row g-4 mb-5">
    
    <div class="col-md-4">
        <a href="#seccion-usuarios" class="text-decoration-none">
            <div class="card admin-card bg-primary text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Usuarios</h5>
                        <span class="fs-2 fs-icon">👥</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalUsuarios</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Libros" asp-action="Index" class="text-decoration-none">
            <div class="card admin-card bg-success text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Libros</h5>
                        <span class="fs-2 fs-icon">📚</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalLibros</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Autores" asp-action="Index" class="text-decoration-none">
            <div class="card admin-card bg-info text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Autores</h5>
                        <span class="fs-2 fs-icon">✍</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalAutores</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <a asp-controller="Prestamos" asp-action="Todos" class="text-decoration-none">
            <div class="card admin-card bg-warning text-dark shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Préstamos Activos</h5>
                        <span class="fs-2 fs-icon">🔄</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.PrestamosActivos</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <a asp-controller="Multas" asp-action="Index" class="text-decoration-none"> <!-- Si no existe acceso global de multas, no importa, visualmente servirá -->
            <div class="card admin-card bg-danger text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Multas Pendientes</h5>
                        <span class="fs-2 fs-icon">💰</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">$ @Model.TotalMultasPendientes</h1>
                </div>
            </div>
        </a>
    </div>

</div>

<!-- ANALÍTICAS DEL SISTEMA -->
<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
            <h5 class="fw-bold mb-4">📈 Tendencia de Préstamos (6 Meses)</h5>
            <div style="height: 300px;">
                <canvas id="tendenciaChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
            <h5 class="fw-bold mb-4">🏆 Libros Más Populares</h5>
            <div style="height: 300px;">
                <canvas id="librosChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <h5 class="fw-bold mb-4">⚠️ Ranking de Mora Histórica (Usuarios)</h5>
            <div style="height: 350px;">
                <canvas id="morososChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- GESTIÓN CENTRALIZADA DE USUARIOS -->
<h4 id="seccion-usuarios" class="fw-bold mb-3 mt-4">⚙️ Gestión de Usuarios</h4>
<p class="text-muted">Administra roles, bloqueos y accesos desde aquí.</p>

<div class="table-responsive card p-2 rounded-4 shadow-sm border-0 bg-transparent">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-primary bg-opacity-10">
            <tr>
                <th class="border-0 ps-3 text-primary">Usuario</th>
                <th class="border-0 text-primary">Email</th>
                <th class="border-0 text-primary">Roles</th>
                <th class="border-0 text-center text-primary">Estado</th>
                <th class="border-0 text-center text-primary">Acciones Centralizadas</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Usuarios)
            {
                <tr>
                    <td class="ps-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                <span class="fs-5 fw-bold">@user.NombreCompleto.Substring(0, 1).ToUpper()</span>
                            </div>
                            <div>
                                <div class="fw-bold">@user.NombreCompleto</div>
                                <small class="text-muted">ID: #@user.Id.Substring(0, 8)...</small>
                            </div>
                        </div>
                    </td>
                    <td class="text-muted">
                        <i class="bi bi-envelope-fill me-1 opacity-50"></i> @user.Email
                    </td>
                    <td>
                        @foreach (var rol in user.Roles)
                        {
                            <span class="badge rounded-pill @(rol == "Admin" ? "bg-warning text-dark border border-warning" : "bg-light text-muted border") px-3">
                                @(rol == "Admin" ? "⭐ " : "")@rol
                            </span>
                        }
                    </td>
                    <td class="text-center">
                        @if (user.EstaBloqueado)
                        {
                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger px-3">
                                <i class="bi bi-shield-lock-fill me-1"></i> Suspendido
                            </span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success px-3">
                                <i class="bi bi-shield-check me-1"></i> Activo
                            </span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-2">
                            @if (user.EstaBloqueado)
                            {
                                <form asp-action="DesbloquearUsuario" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn btn-sm btn-success rounded-3 px-3 shadow-sm" title="Rehabilitar Cuenta">
                                        <i class="bi bi-unlock-fill me-1"></i> Perdonar
                                    </button>
                                </form>
                            }
                            
                            @if (user.Roles.Contains("Admin"))
                            {
                                <form asp-action="QuitarAdmin" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn btn-sm btn-warning rounded-3 px-3 shadow-sm" title="Degradar a Usuario">
                                        <i class="bi bi-person-down me-1"></i> Bajar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="HacerAdmin" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn btn-sm btn-primary rounded-3 px-3 shadow-sm" title="Promover a Admin">
                                        <i class="bi bi-person-up me-1"></i> Ascender
                                    </button>
                                </form>
                            }
                            <form asp-action="EliminarUsuario" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-danger rounded-3 px-3 shadow-sm"
                                        onclick="return confirm('¿Estás SEGURO de eliminar al usuario? También borrará todo su historial.')">
                                    <i class="bi bi-trash3-fill me-1"></i> Eliminar
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctxTendencia = document.getElementById('tendenciaChart').getContext('2d');
            const ctxLibros = document.getElementById('librosChart').getContext('2d');
            const ctxMorosos = document.getElementById('morososChart').getContext('2d');

            // --- DETECCION DE TEMA PARA COLORES ---
            const isDarkMode = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            const labelColor = isDarkMode ? '#adb5bd' : '#6c757d';
            const gridColor = isDarkMode ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';

            const palette = [
                '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', 
                '#FF9F40', '#76D7C4', '#F7DC6F', '#AF7AC5', '#E7E9ED'
            ];

            const gradientBlue = ctxTendencia.createLinearGradient(0, 0, 0, 300);
            gradientBlue.addColorStop(0, 'rgba(54, 162, 235, 0.5)');
            gradientBlue.addColorStop(1, 'rgba(54, 162, 235, 0.0)');

            // 1. Gráfico de Tendencia
            new Chart(ctxTendencia, {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.LabelsTendencia)),
                    datasets: [{
                        label: 'Préstamos Mensuales',
                        data: @Html.Raw(Json.Serialize(Model.ValoresTendencia)),
                        borderColor: '#36A2EB',
                        backgroundColor: gradientBlue,
                        fill: true,
                        tension: 0.4,
                        borderWidth: 4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#36A2EB',
                        pointRadius: 6,
                        pointHoverRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            grid: { color: gridColor },
                            ticks: { color: labelColor, font: { weight: 'bold' } }
                        },
                        x: { 
                            grid: { display: false },
                            ticks: { color: labelColor }
                        }
                    }
                }
            });

            // 2. Gráfico de Libros Populares
            new Chart(ctxLibros, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.LabelsLibrosPopulares)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.ValoresLibrosPopulares)),
                        backgroundColor: palette.slice(0, 5),
                        hoverOffset: 15,
                        borderColor: isDarkMode ? '#1e293b' : '#fff',
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            labels: { 
                                color: labelColor,
                                usePointStyle: true, 
                                padding: 20 
                            }
                        }
                    }
                }
            });

            // 3. Gráfico de Morosos
            new Chart(ctxMorosos, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.LabelsMorosos)),
                    datasets: [
                        {
                            label: 'Monto en Mora ($)',
                            data: @Html.Raw(Json.Serialize(Model.ValoresMorosos)),
                            backgroundColor: 'rgba(255, 99, 132, 0.8)',
                            borderColor: '#FF6384',
                            borderWidth: 1,
                            borderRadius: 10,
                            xAxisID: 'x-monto',
                            barThickness: 25
                        },
                        {
                            label: 'Días de Retraso',
                            data: @Html.Raw(Json.Serialize(Model.ValoresDiasMora)),
                            backgroundColor: 'rgba(255, 159, 64, 0.8)',
                            borderColor: '#FF9F40',
                            borderWidth: 1,
                            borderRadius: 10,
                            xAxisID: 'x-dias',
                            barThickness: 25
                        }
                    ]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: { left: 10, right: 10 } },
                    scales: {
                        'x-monto': { 
                            type: 'linear',
                            position: 'bottom',
                            beginAtZero: true, 
                            grid: { color: gridColor },
                            title: { display: true, text: 'Monto ($)', color: isDarkMode ? '#FF6384' : '#FF6384', font: { weight: 'bold' } },
                            ticks: { color: labelColor }
                        },
                        'x-dias': { 
                            type: 'linear',
                            position: 'top',
                            beginAtZero: true, 
                            grid: { display: false },
                            title: { display: true, text: 'Días de Mora', color: isDarkMode ? '#FF9F40' : '#FF9F40', font: { weight: 'bold' } },
                            ticks: { color: labelColor }
                        },
                        y: { 
                            grid: { display: false }, 
                            ticks: { color: labelColor, font: { weight: 'bold' } } 
                        }
                    },
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            labels: { color: labelColor }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0,0,0,0.8)',
                            padding: 12,
                            cornerRadius: 10
                        }
                    }
                }
            });
        });
    </script>
}