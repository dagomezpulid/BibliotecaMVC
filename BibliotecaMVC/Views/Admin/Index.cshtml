@model BibliotecaMVC.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Panel de Control";
}


<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">📊 Panel de Control</h2>
    <span class="text-muted">Vista General de Biblioteca</span>
</div>

<!-- ESTADÍSTICAS PRINCIPALES (TARJETAS NAVEGABLES) -->
<div class="row g-4 mb-5">
    
    <div class="col-md-4">
        <a href="#seccion-usuarios" class="text-decoration-none">
            <div class="card admin-card bg-primary text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Usuarios</h5>
                        <span class="fs-2 fs-icon">👥</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalUsuarios</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Libros" asp-action="Index" class="text-decoration-none">
            <div class="card admin-card bg-success text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Libros</h5>
                        <span class="fs-2 fs-icon">📚</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalLibros</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Autores" asp-action="Index" class="text-decoration-none">
            <div class="card admin-card bg-info text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Autores</h5>
                        <span class="fs-2 fs-icon">✍</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalAutores</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <a asp-controller="Prestamos" asp-action="Todos" class="text-decoration-none">
            <div class="card admin-card bg-warning text-dark shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Préstamos Activos</h5>
                        <span class="fs-2 fs-icon">🔄</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">@Model.PrestamosActivos</h1>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <a asp-controller="Multas" asp-action="Index" class="text-decoration-none"> <!-- Si no existe acceso global de multas, no importa, visualmente servirá -->
            <div class="card admin-card bg-danger text-white shadow border-0 rounded-4 p-3 h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title fw-normal mb-0">Multas Pendientes</h5>
                        <span class="fs-2 fs-icon">💰</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-0">$ @Model.TotalMultasPendientes</h1>
                </div>
            </div>
        </a>
    </div>

</div>

<!-- ANALÍTICAS DEL SISTEMA -->
<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
            <h5 class="fw-bold mb-4">📈 Tendencia de Préstamos (6 Meses)</h5>
            <div style="height: 300px;">
                <canvas id="tendenciaChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
            <h5 class="fw-bold mb-4">🏆 Libros Más Populares</h5>
            <div style="height: 300px;">
                <canvas id="librosChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <h5 class="fw-bold mb-4">⚠️ Ranking de Mora Histórica (Usuarios)</h5>
            <div style="height: 350px;">
                <canvas id="morososChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- GESTIÓN CENTRALIZADA DE USUARIOS -->
<h4 id="seccion-usuarios" class="fw-bold mb-3 mt-4">⚙️ Gestión de Usuarios</h4>
<p class="text-muted">Administra roles, bloqueos y accesos desde aquí.</p>

<div class="table-responsive card p-3 rounded-4 shadow-sm border-0">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th class="border-0">Nombre</th>
                <th class="border-0">Email</th>
                <th class="border-0">Rol</th>
                <th class="border-0 text-center">Estado</th>
                <th class="border-0 text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Usuarios)
            {
                <tr>
                    <td class="fw-semibold text-dark">@user.NombreCompleto</td>
                    <td class="text-muted">@user.Email</td>
                    <td>
                        <span class="badge bg-secondary">@string.Join(", ", user.Roles)</span>
                    </td>
                    <td class="text-center">
                        @if (user.EstaBloqueado)
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Suspendido</span>
                        }
                        else
                        {
                            <span class="badge bg-success bg-opacity-10 text-success border border-success">Limpio</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (user.EstaBloqueado)
                        {
                            <form asp-action="DesbloquearUsuario" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="btn btn-outline-success btn-sm shadow-sm" title="Rehabilitar Cuenta">🔓 Perdonar</button>
                            </form>
                        }
                        
                        @if (user.Roles.Contains("Admin"))
                        {
                            <form asp-action="QuitarAdmin" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="btn btn-warning btn-sm shadow-sm" title="Quitar rol de Administrador">⬇️ Quitar Admin</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="HacerAdmin" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="btn btn-success btn-sm shadow-sm" title="Convertir a Administrador">⭐ Hacer Admin</button>
                            </form>
                        }
                        <form asp-action="EliminarUsuario" method="post" style="display:inline;" class="ms-1">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-danger btn-sm shadow-sm"
                                    onclick="return confirm('¿Estás SEGURO de eliminar al usuario? También borrará todo su historial.')">
                                🗑️ Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Configuración Global de Chart.js para que respete el modo oscuro si es posible
            const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            const colorText = isDark ? '#f1f5f9' : '#212529';
            const colorGrid = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';

            Chart.defaults.color = colorText;
            Chart.defaults.borderColor = colorGrid;

            // 1. Gráfico de Tendencia (Línea)
            new Chart(document.getElementById('tendenciaChart'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.LabelsTendencia)),
                    datasets: [{
                        label: 'Préstamos Mensuales',
                        data: @Html.Raw(Json.Serialize(Model.ValoresTendencia)),
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, grid: { color: colorGrid } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // 2. Gráfico de Libros Populares (Doughnut)
            new Chart(document.getElementById('librosChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.LabelsLibrosPopulares)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.ValoresLibrosPopulares)),
                        backgroundColor: [
                            '#0d6efd', '#198754', '#0dcaf0', '#ffc107', '#dc3545'
                        ],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

            // 3. Gráfico de Morosos (Barras Horizontales con DOBLE EJE para legibilidad)
            new Chart(document.getElementById('morososChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.LabelsMorosos)),
                    datasets: [
                        {
                            label: 'Monto Total en Mora ($)',
                            data: @Html.Raw(Json.Serialize(Model.ValoresMorosos)),
                            backgroundColor: '#dc3545',
                            borderRadius: 5,
                            xAxisID: 'x-monto'
                        },
                        {
                            label: 'Días de Mora Acumulados',
                            data: @Html.Raw(Json.Serialize(Model.ValoresDiasMora)),
                            backgroundColor: '#fd7e14',
                            borderRadius: 5,
                            xAxisID: 'x-dias'
                        }
                    ]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        'x-monto': { 
                            type: 'linear',
                            position: 'bottom',
                            beginAtZero: true, 
                            grid: { color: colorGrid },
                            title: { display: true, text: 'Monto en Deuda ($)', color: '#dc3545' },
                            ticks: { color: '#dc3545' }
                        },
                        'x-dias': { 
                            type: 'linear',
                            position: 'top',
                            beginAtZero: true, 
                            grid: { display: false }, // Evitar ruidos visuales
                            title: { display: true, text: 'Días de Retraso', color: '#fd7e14' },
                            ticks: { color: '#fd7e14' }
                        },
                        y: { grid: { display: false } }
                    },
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.datasetIndex === 0) {
                                        label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(context.parsed.x);
                                    } else {
                                        label += context.parsed.x + ' días';
                                    }
                                    return label;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}