@model BibliotecaMVC.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Administrativo";
}

<h2 class="mb-4">📊 Panel Administrativo</h2>

<div class="row g-4">

    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center p-3">
            <h5>👥 Usuarios</h5>
            <h2>@Model.TotalUsuarios</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center p-3">
            <h5>📚 Libros</h5>
            <h2>@Model.TotalLibros</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center p-3">
            <h5>✍ Autores</h5>
            <h2>@Model.TotalAutores</h2>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 text-center p-3">
            <h5>🔄 Préstamos Activos</h5>
            <h2>@Model.PrestamosActivos</h2>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 text-center p-3">
            <h5>💰 Multas Pendientes</h5>
            <h2>$ @Model.TotalMultasPendientes</h2>
        </div>
    </div>

</div>