@model IEnumerable<BibliotecaMVC.Models.Prestamo>

<h2>Mis Préstamos</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Libro</th>
            <th>Fecha préstamo</th>
            <th>Fecha límite</th>
            <th>Fecha devolución</th>
            <th>Estado</th>
            <th>Multa</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            var devuelto = p.FechaDevolucionReal != null;

            <tr>
                <td>@p.Libro?.Titulo</td>
                <td>@p.FechaPrestamo.ToShortDateString()</td>
                <td>@p.FechaDevolucionProgramada.ToShortDateString()</td>
                <td>@p.FechaDevolucionReal?.ToShortDateString()</td>

                <td>
                    @if (p.Multa != null && !p.Multa.Pagada)
                    {
                        <span class="badge bg-danger">
                            Multa pendiente
                        </span>
                    }
                    else if (devuelto)
                    {
                        <span class="badge bg-success">
                            Devuelto
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">
                            Activo
                        </span>
                    }
                </td>

                <td>
                    @if (p.Multa != null)
                    {
                        <span class="text-danger">
                            $@p.Multa.Monto.ToString("N0")
                        </span>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>