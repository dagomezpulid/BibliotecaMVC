@model IEnumerable<BibliotecaMVC.Models.Prestamo>

@{
    ViewData["Title"] = "Gestión de Préstamos";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">🔄 Control de Préstamos</h2>
    <div>
        <a class="btn btn-outline-secondary shadow-sm" asp-controller="Admin" asp-action="Index">
            📊 Volver al Dashboard
        </a>
    </div>
</div>

<div class="table-responsive bg-white p-3 rounded-4 shadow-sm border-0">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th class="border-0">Libro</th>
                <th class="border-0">Fecha Préstamo</th>
                <th class="border-0">Fecha Límite</th>
                <th class="border-0">Devolución</th>
                <th class="border-0 text-center">Estado</th>
                <th class="border-0 text-center">Multa</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any()) {
                @foreach (var p in Model)
                {
                    var devuelto = p.FechaDevolucionReal != null;

                    <tr>
                        <td class="fw-semibold text-dark">@p.Libro?.Titulo</td>
                        <td class="text-muted">@p.FechaPrestamo.ToShortDateString()</td>
                        <td class="text-muted">@p.FechaDevolucionProgramada.ToShortDateString()</td>
                        <td class="text-muted fw-bold">@(devuelto ? p.FechaDevolucionReal?.ToShortDateString() : "-")</td>

                        <td class="text-center">
                            @if (p.Multa != null && !p.Multa.Pagada)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">
                                    Multa Pendiente
                                </span>
                            }
                            else if (devuelto)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success">
                                    Devuelto
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">
                                    Activo
                                </span>
                            }
                        </td>

                        <td class="text-center fw-bold">
                            @if (p.Multa != null)
                            {
                                <span class="text-danger">
                                    $@p.Multa.Monto.ToString("N0")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            } else {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No hay préstamos registrados en el sistema.</td>
                </tr>
            }
        </tbody>
    </table>
</div>