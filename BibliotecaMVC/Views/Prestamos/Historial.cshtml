@model IEnumerable<BibliotecaMVC.Models.Prestamo>

<h2>Historial de Préstamos</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Libro</th>
            <th>Solicitante</th>
            <th>Fecha Préstamo</th>
            <th>Fecha Límite</th>
            <th>Fecha Devolución</th>
            <th>Días Retraso</th>
            <th>Multa</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            var devuelto = p.FechaDevolucionReal != null;

            var diasRetraso = 0;

            if (devuelto && p.FechaDevolucionReal > p.FechaDevolucionProgramada)
            {
                diasRetraso =
                (p.FechaDevolucionReal.Value - p.FechaDevolucionProgramada).Days;
            }

            <tr>
                <td>@p.Libro?.Titulo</td>
                <td>@p.Usuario?.NombreCompleto</td>
                <td>@p.FechaPrestamo.ToShortDateString()</td>
                <td>@p.FechaDevolucionProgramada.ToShortDateString()</td>
                <td>@p.FechaDevolucionReal?.ToShortDateString()</td>

                <td>
                    @if (diasRetraso > 0)
                    {
                        <span class="text-danger">@diasRetraso</span>
                    }
                    else
                    {
                        <span>0</span>
                    }
                </td>

                <td>
                    @if (p.Multa != null)
                    {
                        <span class="text-danger">
                            $@p.Multa.Monto
                        </span>
                    }
                    else
                    {
                        <span>$0</span>
                    }
                </td>

                <td>
                    @if (p.Multa != null && !p.Multa.Pagada)
                    {
                        <span class="badge bg-danger">Multa pendiente</span>
                    }
                    else if (devuelto)
                    {
                        <span class="badge bg-success">Devuelto</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Activo</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-secondary" asp-action="Index">
    Volver a Préstamos Activos
</a>