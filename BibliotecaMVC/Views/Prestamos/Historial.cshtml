@model IEnumerable<BibliotecaMVC.Models.Prestamo>

@{
    ViewData["Title"] = "Historial de Préstamos";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">📜 Historial de Préstamos</h2>
    <div>
        <a class="btn btn-outline-secondary shadow-sm" asp-action="Index">
            🏠 Mis Préstamos Activos
        </a>
    </div>
</div>

<div class="table-responsive card p-3 rounded-4 shadow-sm border-0">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th class="border-0">Libro</th>
                <th class="border-0">Fecha Préstamo</th>
                <th class="border-0">Vencimiento</th>
                <th class="border-0">Devolución Real</th>
                <th class="border-0 text-center">Estado</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any()) {
                @foreach (var p in Model)
                {
                    var devuelto = p.FechaDevolucionReal != null;
                    var diasRetraso = 0;

                    if (devuelto && p.FechaDevolucionReal > p.FechaDevolucionProgramada)
                    {
                        diasRetraso = (p.FechaDevolucionReal.Value - p.FechaDevolucionProgramada).Days;
                    }

                    <tr>
                        <td class="fw-semibold text-dark">@p.Libro?.Titulo</td>
                        <td class="text-muted">@p.FechaPrestamo.ToShortDateString()</td>
                        <td class="text-muted">@p.FechaDevolucionProgramada.ToShortDateString()</td>
                        <td class="text-muted fw-bold">@(devuelto ? p.FechaDevolucionReal?.ToShortDateString() : "-")</td>

                        <td class="text-center">
                            @if (p.Multa != null && !p.Multa.Pagada)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Multa Pendiente</span>
                            }
                            else if (devuelto && diasRetraso > 0)
                            {
                                <span class="badge bg-warning bg-opacity-10 text-dark border border-warning">Tardío (@diasRetraso días)</span>
                            }
                            else if (devuelto)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success">Devuelto a tiempo</span>
                            }
                            else
                            {
                                <span class="badge bg-info bg-opacity-10 text-info border border-info">Activo</span>
                            }
                        </td>
                    </tr>
                }
            } else {
                 <tr>
                    <td colspan="5" class="text-center text-muted py-4">No hay historial de préstamos.</td>
                </tr>
            }
        </tbody>
    </table>
</div>