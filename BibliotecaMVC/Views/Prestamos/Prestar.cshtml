@model BibliotecaMVC.Models.Libro

@{
    ViewData["Title"] = "Confirmar Préstamo";
}

<div class="row justify-content-center mt-4 mb-5 pb-5">
    <div class="col-lg-10 mt-3">
        <div class="card shadow rounded-4 border-0 overflow-hidden">
            <div class="card-header bg-primary text-white py-3 border-0">
                <h4 class="mb-0 fw-bold text-center"><i class="bi bi-bookmark-check me-2"></i>Pasarela de Préstamo Digital</h4>
            </div>
            
            <div class="card-body p-0">
                <div class="row g-0">
                    <!-- Columna Visual del Libro -->
                    <div class="col-md-5 col-lg-4 bg-light p-4 d-flex flex-column align-items-center justify-content-center border-end">
                        <div class="book-cover-container shadow-sm mb-3 rounded-2" style="width: 200px; height: 300px; max-width: 100%;">
                            @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                            {
                                <img src="@Model.ImagenUrl" class="book-cover rounded-2" alt="@Model.Titulo">
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-secondary bg-opacity-25 rounded-2">
                                    <span class="display-3 opacity-50">📖</span>
                                </div>
                            }
                        </div>
                        
                        <div class="text-center mt-2 w-100">
                            @if (Model.Stock > 0)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success w-100 d-block p-2">✅ Disponible para Préstamo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger w-100 d-block p-2">❌ Agotado</span>
                            }
                        </div>
                    </div>

                    <!-- Columna de Detalles y Formulario -->
                    <div class="col-md-7 col-lg-8 p-4 p-lg-5">
                        <div class="mb-2">
                            @if (Model.Categorias != null && Model.Categorias.Any())
                            {
                                foreach (var cat in Model.Categorias)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill category-badge me-1">@cat.Nombre</span>
                                }
                            }
                        </div>

                        <h2 class="fw-bold mb-2 text-dark">@Model.Titulo</h2>
                        <h5 class="text-muted mb-4"><span class="me-2 d-inline-block opacity-50">✍️</span>@Model.Autor?.Nombre</h5>
                        
                        @if (!string.IsNullOrEmpty(Model.Descripcion))
                        {
                            <div class="mb-4">
                                <h6 class="fw-bold text-dark text-uppercase small opacity-75 letter-spacing-1">Sinopsis</h6>
                                <p class="text-muted small lh-lg" style="display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;">
                                    @Model.Descripcion
                                </p>
                            </div>
                        }

                        <hr class="my-4 text-muted border-top border-opacity-10">

                        <!-- Formulario de Préstamo -->
                        <form asp-controller="Prestamos" asp-action="Prestar" method="post" class="mt-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="libroId" value="@Model.Id" />

                            <div class="mb-4 bg-light bg-opacity-50 p-4 rounded-4 border">
                                <label for="diasPrestamo" class="form-label fw-bold text-dark mb-3"><i class="bi bi-calendar3 me-2"></i>¿Durante cuántos días solicitarás la licencia digital?</label>
                                <div class="input-group input-group-lg shadow-sm">
                                    <input type="date" id="fechaSelector" class="form-control text-center text-primary fw-bold bg-white" 
                                           min="@DateTime.Now.AddDays(2).ToString("yyyy-MM-dd")" 
                                           max="@DateTime.Now.AddDays(20).ToString("yyyy-MM-dd")" 
                                           value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-dd")" 
                                           title="Elegir Fecha Exacta del Calendario"/>
                                    
                                    <span class="input-group-text bg-white text-muted fs-6 border-start-0 border-end-0">equivale a</span>
                                    
                                    <input type="number" id="diasPrestamo" name="diasPrestamo" class="form-control text-center fw-bold text-dark border-start-0" min="2" max="20" value="7" required />
                                    <span class="input-group-text bg-light text-muted fw-semibold">Días</span>
                                </div>
                                <div class="form-text mt-3 text-center text-secondary small">
                                    <i class="bi bi-info-circle me-1"></i> Rango permitido: Entre 2 y 20 días. Pasado este tiempo, el acceso se revocará.
                                </div>
                            </div>
                            
                            <div class="d-grid gap-3 d-md-flex justify-content-md-end mt-4">
                                <a asp-controller="Home" asp-action="Index" class="btn btn-light border btn-lg px-4 rounded-pill">
                                    Cancelar
                                </a>
                                <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow rounded-pill" @(Model.Stock <= 0 ? "disabled" : "")>
                                    <i class="bi bi-check2-circle me-2"></i>Confirmar Préstamo
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const datePicker = document.getElementById("fechaSelector");
        const daysInput = document.getElementById("diasPrestamo");
        
        // Calcular "Hoy"
        const today = new Date();
        today.setHours(0,0,0,0);

        const buildDateParams = (dias) => {
            let targetDate = new Date();
            targetDate.setDate(targetDate.getDate() + dias);
            return targetDate.toISOString().split('T')[0];
        };

        // Escuchar cuando el usuario escoge una fecha
        datePicker.addEventListener("change", function () {
            const selectedDate = new Date(this.value + "T00:00:00");
            const diffTime = selectedDate - today;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            if (diffDays >= 2 && diffDays <= 20) {
                daysInput.value = diffDays;
            } else {
                if (diffDays < 2) { daysInput.value = 2; datePicker.value = buildDateParams(2); }
                if (diffDays > 20) { daysInput.value = 20; datePicker.value = buildDateParams(20); }
            }
        });

        // Escuchar cuando el usuario tipea el número de días
        daysInput.addEventListener("input", function () {
            let days = parseInt(this.value);
            if (!isNaN(days) && days >= 2 && days <= 20) {
                datePicker.value = buildDateParams(days);
            }
        });
    });
</script>
}