@model int

@{
    ViewData["Title"] = "Confirmar Préstamo";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 mt-4">
        <div class="card shadow rounded-4 border-0">
            <div class="card-header bg-warning text-dark rounded-top-4 py-3">
                <h4 class="mb-0 fw-bold text-center">📖 Confirmar Préstamo</h4>
            </div>
            <div class="card-body p-4 text-center">
                
                <h5 class="text-muted mb-4">¿Deseas solicitar en préstamo el siguiente libro?</h5>
                
                <h3 class="fw-bold mb-4 text-dark">@ViewBag.LibroTitulo</h3>
                
                <div class="alert alert-info bg-opacity-10 py-2 shadow-sm rounded-3 d-inline-block px-4 border-info mb-4">
                    <small>⏰ Elige tu tiempo de lectura sabiamente. Máximo 20 días.</small>
                </div>
                
                <form asp-controller="Prestamos" asp-action="Prestar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="libroId" value="@Model" />

                    <div class="mb-4 text-start bg-light p-3 rounded-3 border shadow-sm">
                        <label for="diasPrestamo" class="form-label fw-bold text-dark">¿Cuándo devolverás el libro?</label>
                        <div class="input-group input-group-lg">
                            <input type="date" id="fechaSelector" class="form-control text-center text-primary fw-bold" 
                                   min="@DateTime.Now.AddDays(2).ToString("yyyy-MM-dd")" 
                                   max="@DateTime.Now.AddDays(20).ToString("yyyy-MM-dd")" 
                                   value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-dd")" 
                                   title="Elegir Fecha Exacta del Calendario"/>
                            
                            <span class="input-group-text bg-white text-muted fs-6">equivale a</span>
                            
                            <input type="number" id="diasPrestamo" name="diasPrestamo" class="form-control text-center fw-bold text-dark" min="2" max="20" value="7" required />
                            <span class="input-group-text bg-white text-muted">Días</span>
                        </div>
                        <div class="form-text mt-2 text-center text-secondary"><small><i>*Tip: Usa el calendario para elegir la fecha o teclea los días directamente (Mínimo 2, Máximo 20).</i></small></div>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <button type="submit" class="btn btn-warning btn-lg fw-bold px-5 shadow-sm">
                            Realizar Préstamo
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light border btn-lg fw-bold px-4">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const datePicker = document.getElementById("fechaSelector");
        const daysInput = document.getElementById("diasPrestamo");
        
        // Calcular "Hoy" puro para matemáticas de fechas (forzando medianoche)
        const today = new Date();
        today.setHours(0,0,0,0);

        const buildDateParams = (dias) => {
            let targetDate = new Date();
            targetDate.setDate(targetDate.getDate() + dias);
            // Formato normalizado YYYY-MM-DD
            return targetDate.toISOString().split('T')[0];
        };

        // Escuchar cuando el usuario escoge una fecha en el Calendario
        datePicker.addEventListener("change", function () {
            const selectedDate = new Date(this.value + "T00:00:00");
            const diffTime = selectedDate - today;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            if (diffDays >= 2 && diffDays <= 20) {
                daysInput.value = diffDays;
            } else {
                // Candado de seguridad front-end si rompen o escriben fechas inválidas
                if (diffDays < 2) { daysInput.value = 2; datePicker.value = buildDateParams(2); }
                if (diffDays > 20) { daysInput.value = 20; datePicker.value = buildDateParams(20); }
            }
        });

        // Escuchar cuando el usuario tipea el número de días
        daysInput.addEventListener("input", function () {
            let days = parseInt(this.value);
            if (!isNaN(days) && days >= 2 && days <= 20) {
                datePicker.value = buildDateParams(days);
            }
        });
    });
</script>