@model IEnumerable<BibliotecaMVC.Models.Prestamo>

@{
    ViewData["Title"] = "Mis Préstamos Activos";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">📖 Mis Préstamos Activos</h2>
    <div>
        <a class="btn btn-outline-secondary shadow-sm me-2" asp-controller="Home" asp-action="Index">
            🏠 Volver
        </a>
        <a class="btn btn-info text-white shadow-sm" asp-action="Historial">
            📜 Ver Historial
        </a>
    </div>
</div>

<div class="table-responsive card p-2 rounded-4 shadow-sm border-0 bg-transparent">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-primary bg-opacity-10">
            <tr>
                <th class="border-0 ps-3 text-primary">Título del Libro</th>
                <th class="border-0 text-center text-primary">Fecha Préstamo</th>
                <th class="border-0 text-center text-primary">Vencimiento</th>
                <th class="border-0 text-center text-primary">Estado de Tiempo</th>
                <th class="border-0 text-center text-primary">Acciones de Lectura</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any()) {
                @foreach (var p in Model)
                {
                    var diasRestantes = (p.FechaDevolucionProgramada - DateTime.Now).Days;

                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-2">📖</span>
                                <div>
                                    <div class="fw-bold text-dark">@(p.Libro?.Titulo ?? "Sin Título")</div>
                                    <small class="text-muted">ID: #@p.Id</small>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted text-center">@p.FechaPrestamo.ToShortDateString()</td>
                        <td class="text-center">
                            <span class="@(diasRestantes < 0 ? "text-danger fw-bold" : "text-dark")">
                                @p.FechaDevolucionProgramada.ToShortDateString()
                            </span>
                        </td>
                        
                        <td class="text-center">
                            @if (diasRestantes < 0)
                            {
                                <span class="badge rounded-pill bg-danger shadow-sm px-3">
                                    <i class="bi bi-exclamation-octagon-fill me-1"></i> Atrasado (@Math.Abs(diasRestantes) d)
                                </span>
                            }
                            else if (diasRestantes <= 2)
                            {
                                <span class="badge rounded-pill bg-warning text-dark shadow-sm px-3">
                                    <i class="bi bi-hourglass-split me-1"></i> Vence pronto (@diasRestantes d)
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success px-3">
                                    <i class="bi bi-calendar-check me-1"></i> Al día (@diasRestantes d)
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                @if (p.Libro?.Archivos != null && p.Libro.Archivos.Any())
                                {
                                    <a asp-action="Leer" asp-route-id="@p.Id" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm" title="Abrir Visor">
                                        <i class="bi bi-book-half me-1"></i> Leer
                                    </a>
                                }
                                <button class="btn btn-outline-success btn-sm rounded-pill px-3 border-0 shadow-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalDevolver"
                                        data-id="@p.Id"
                                        data-libro="@(p.Libro?.Titulo ?? "Este libro")">
                                    <i class="bi bi-arrow-repeat me-1"></i> Devolver
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            } else {
                <tr>
                    <td colspan="5" class="text-center text-muted py-5">
                        <i class="bi bi-journal-x d-block fs-1 mb-2 opacity-25"></i>
                        No tienes ningún préstamo activo en este momento.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Devolver -->
<div class="modal fade" id="modalDevolver" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">

            <form action="@Url.Action("Devolver", "Prestamos")" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">↩️ Confirmar Devolución</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body text-center mt-3 mb-2">
                    <h5 class="text-muted mb-3">¿Estás seguro que deseas devolver el libro?</h5>
                    <div class="bg-light p-3 rounded-3 shadow-sm border border-light">
                        <strong id="tituloLibro" class="fs-5 text-primary"></strong>
                    </div>
                    <input type="hidden" name="id" id="prestamoId" />
                </div>

                <div class="modal-footer border-0 justify-content-center">
                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-success px-4 shadow-sm">
                        Confirmar Devolución
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var modal = document.getElementById('modalDevolver');
        modal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('prestamoId').value = button.getAttribute('data-id');
            document.getElementById('tituloLibro').textContent = button.getAttribute('data-libro');
        });
    </script>
}
