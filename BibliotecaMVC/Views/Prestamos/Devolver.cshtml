@model BibliotecaMVC.Models.Prestamo

<h2>Devolver Libro</h2>

<p><strong>Libro:</strong> @Model.Libro.Titulo</p>
<p>
    <strong>Solicitante:</strong> @Model.Usuario?.NombreCompleto</p>

<form asp-action="Devolver" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-success">Confirmar Devolución</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
