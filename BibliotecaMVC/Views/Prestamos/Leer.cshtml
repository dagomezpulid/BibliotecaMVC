@model BibliotecaMVC.Models.Libro

@{
    ViewData["Title"] = "Leer Libro";
    
    var primerArchivo = Model.Archivos?.FirstOrDefault();
    var formato = primerArchivo?.Formato?.ToLower() ?? "";
    var isPdf = formato.EndsWith("pdf");
    var isDocx = formato.EndsWith("docx");
    var prestamoId = ViewBag.PrestamoId;
    var paginaInicial = ViewBag.PaginaGuardada ?? 1;
}

<!-- Contenedor inmersivo fijado al viewport para evitar desplazamientos por el Layout -->
<div id="immersive-reader" class="d-flex flex-column bg-dark">
    
    <!-- Barra Superior de Navegación Estilizada -->
    <div class="d-flex justify-content-between align-items-center bg-dark text-white p-2 px-3 border-bottom border-secondary shadow-lg" style="height: 65px; z-index: 1100;">
        <div class="d-flex align-items-center">
            <a asp-controller="Prestamos" asp-action="Index" class="btn btn-info btn-sm fw-bold px-3 py-2 rounded-pill shadow-sm me-3">
                <i class="bi bi-arrow-left"></i> Volver a Mis Préstamos
            </a>
            <h5 class="mb-0 fw-bold border-start ps-3 py-1 border-secondary d-none d-md-block text-truncate" style="max-width: 300px;">
                <i class="bi bi-book me-2 text-warning"></i>@Model.Titulo
            </h5>
        </div>

        <!-- CONTROLES DE PROGRESO DE LECTURA -->
        <div class="d-flex align-items-center bg-white bg-opacity-10 rounded-pill px-3 py-1 shadow-inner">
            <span class="small text-white-50 me-2 d-none d-sm-inline">Vas en la página:</span>
            <input type="number" id="inputPagina" class="form-control form-control-sm border-0 bg-transparent text-white fw-bold text-center" 
                   style="width: 60px;" value="@paginaInicial" min="1" />
            <button id="btnGuardarProgreso" class="btn btn-sm btn-outline-light border-0 rounded-circle ms-1 p-1" title="Guardar Progreso">
                <i class="bi bi-bookmark-star-fill fs-5"></i>
            </button>
            <div id="saveIndicator" class="ms-2 small text-success d-none">
                <i class="bi bi-check-circle-fill"></i> <span class="d-none d-md-inline">Guardado</span>
            </div>
        </div>
        
        <div class="d-flex align-items-center">
            <a asp-action="DescargarLibro" asp-route-id="@prestamoId" class="btn btn-warning btn-sm shadow-sm fw-bold px-4 rounded-pill d-none d-lg-inline-block">
                <i class="bi bi-download me-2"></i>Descargar
            </a>
            <button class="btn btn-dark btn-sm rounded-circle ms-2" onclick="toggleFullScreen()" title="Pantalla Completa">
                <i class="bi bi-arrows-fullscreen"></i>
            </button>
        </div>
    </div>

    <!-- Area del Lector -->
    <div class="flex-grow-1 bg-secondary position-relative w-100" style="height: calc(100vh - 65px);">
        @if (isPdf)
        {
            <iframe id="readerIframe" 
                    src="/Prestamos/ArchivoLectura/@prestamoId#page=@paginaInicial&toolbar=0" 
                    title="Visor de PDF de @Model.Titulo"
                    class="w-100 h-100 border-0" 
                    style="display: block; background-color: #525659;"
                    allowfullscreen>
            </iframe>
        }
        else if (isDocx)
        {
            <div id="word-container" class="w-100 h-100 p-0 p-md-4 overflow-hidden bg-dark d-flex justify-content-center position-relative">
                <div id="word-render-area" class="my-0" style="width: 100%; max-width: 900px;">
                    <div class="d-flex justify-content-center align-items-center h-100 py-5" id="word-loader">
                        <div class="spinner-border text-info" style="width: 3rem; height: 3rem;" role="status">
                            <span class="visually-hidden">Cargando documento...</span>
                        </div>
                        <h4 class="ms-3 fw-bold text-white-50">Preparando motor de lectura Word...</h4>
                    </div>
                </div>

                <!-- Botones de Navegación Virtual (Solo para Word) -->
                <button id="prevPageWord" class="btn btn-dark btn-lg rounded-circle shadow-lg position-absolute start-0 top-50 translate-middle-y ms-4 border-secondary opacity-50 hover-opacity-100" style="z-index: 1200; width: 60px; height: 60px;">
                    <i class="bi bi-chevron-left fs-3"></i>
                </button>
                <button id="nextPageWord" class="btn btn-dark btn-lg rounded-circle shadow-lg position-absolute end-0 top-50 translate-middle-y me-4 border-secondary opacity-50 hover-opacity-100" style="z-index: 1200; width: 60px; height: 60px;">
                    <i class="bi bi-chevron-right fs-3"></i>
                </button>
            </div>
        }
        else
        {
            <div class="w-100 h-100 d-flex flex-column justify-content-center align-items-center text-center p-3">
                <div class="bg-white p-5 rounded-4 shadow-lg border" style="max-width: 600px;">
                    <span class="display-3 text-info opacity-75 mb-4 d-block">
                        <i class="bi bi-cloud-arrow-down"></i>
                    </span>
                    <h3 class="fw-bold text-dark">Formato Externo Detectado</h3>
                    <p class="text-muted fs-6 mt-3 mb-4">
                        El libro "<strong>@Model.Titulo</strong>" requiere una aplicación externa para lectura fluida.
                    </p>
                    <a asp-action="DescargarLibro" asp-route-id="@prestamoId" class="btn btn-primary btn-lg fw-bold px-5 py-3 rounded-pill shadow">
                        <i class="bi bi-download me-2"></i>Descargar para Leer
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    #immersive-reader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 2000;
    }

    header, footer, nav { display: none !important; }
    body { overflow: hidden !important; background-color: #000 !important; }

    .shadow-inner {
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.3);
    }

    #inputPagina:focus {
        outline: none;
        box-shadow: none;
    }

    /* Animación de guardado */
    @@keyframes fadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
    }
    .fade-out {
        animation: fadeOut 2s forwards;
    }
    /* Estilo para el renderizado de docx-preview - Efecto Hoja Física */
    .docx-wrapper {
        background-color: transparent !important;
        padding: 0 !important;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .docx {
        box-shadow: 0 10px 30px rgba(0,0,0,0.8) !important;
        margin-bottom: 3rem !important;
        border: 1px solid #ddd !important;
        background-color: white !important;
        padding: 50pt !important; /* Margen de impresión estándar */
    }
    #word-container {
        scroll-behavior: smooth;
        background: radial-gradient(circle, #2c2f33 0%, #1a1c1e 100%);
        overflow-y: scroll !important; /* Permitir scroll pero ocultar barra si se prefiere */
    }
    .hover-opacity-100:hover {
        opacity: 1 !important;
        background-color: #0dcaf0 !important;
        color: black !important;
    }
</style>

@section Scripts {
    @if (isDocx)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
        <script src="https://unpkg.com/docx-preview/dist/docx-preview.min.js"></script>
    }

    <script>
        const btnGuardar = document.getElementById('btnGuardarProgreso');
        const inputPagina = document.getElementById('inputPagina');
        const indicator = document.getElementById('saveIndicator');
        const libroId = @Model.Id;
        const isDocx = @isDocx.ToString().ToLower();
        const prestamoId = @prestamoId;

        // Lógica específica para Word con Paginación Virtual
        if (isDocx) {
            const wordContainer = document.getElementById("word-container");
            const wordRenderArea = document.getElementById("word-render-area");
            const wordLoader = document.getElementById("word-loader");
            const btnPrev = document.getElementById("prevPageWord");
            const btnNext = document.getElementById("nextPageWord");

            let totalVirtualPages = 1;

            async function loadWord() {
                try {
                    const response = await fetch(`/Prestamos/ArchivoLectura/${prestamoId}`);
                    const blob = await response.blob();
                    
                    await docx.renderAsync(blob, wordRenderArea, null, {
                        className: "docx",
                        inWrapper: false,
                        ignoreLastRenderedPageBreak: false,
                        useMathMLPolyfill: true
                    });
                    
                    wordLoader.classList.add("d-none");

                    // Calcular páginas virtuales tras el renderizado
                    setTimeout(() => {
                        updateTotalPages();
                        const pagina = @paginaInicial;
                        if (pagina > 1) {
                            irAVirtualPage(pagina);
                        }
                    }, 800);

                } catch (err) {
                    console.error("Error cargando Word:", err);
                    wordRenderArea.innerHTML = `<div class="p-5 text-danger fw-bold text-center text-white">Error al renderizar el documento Word.</div>`;
                }
            }

            function updateTotalPages() {
                const scrollHeight = wordContainer.scrollHeight;
                const clientHeight = wordContainer.clientHeight;
                totalVirtualPages = Math.max(1, Math.ceil(scrollHeight / clientHeight));
                console.log("Total Virtual Pages:", totalVirtualPages);
            }

            function irAVirtualPage(num) {
                if (num < 1) num = 1;
                if (num > totalVirtualPages) num = totalVirtualPages;
                
                const clientHeight = wordContainer.clientHeight;
                wordContainer.scrollTo({
                    top: (num - 1) * clientHeight,
                    behavior: 'smooth'
                });
                inputPagina.value = num;
                saveProgress();
            }

            btnNext.onclick = () => {
                const current = parseInt(inputPagina.value);
                irAVirtualPage(current + 1);
            };

            btnPrev.onclick = () => {
                const current = parseInt(inputPagina.value);
                irAVirtualPage(current - 1);
            };

            // Detectar scroll para actualizar el input de página
            wordContainer.addEventListener('scroll', () => {
                const clientHeight = wordContainer.clientHeight;
                const current = Math.round(wordContainer.scrollTop / clientHeight) + 1;
                if (inputPagina.value != current) {
                    inputPagina.value = current;
                }
            });

            // Atajos de flechas
            document.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowRight' || e.key === 'PageDown') btnNext.click();
                if (e.key === 'ArrowLeft' || e.key === 'PageUp') btnPrev.click();
            });

            loadWord();
            
            inputPagina.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    irAVirtualPage(parseInt(inputPagina.value));
                }
            });
            
            // Recalcular páginas al cambiar el tamaño de la ventana
            window.addEventListener('resize', updateTotalPages);
        }

        // Función para guardar progreso vía AJAX
        async function saveProgress() {
            // Permitimos guardar para Word también
            
            const pagina = parseInt(inputPagina.value);
            if (isNaN(pagina) || pagina < 1) return;

            indicator.classList.remove('d-none', 'fade-out');

            try {
                const response = await fetch('/Prestamos/GuardarProgreso', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ""
                    },
                    body: `libroId=${libroId}&pagina=${pagina}`
                });

                if (response.ok) {
                    setTimeout(() => indicator.classList.add('fade-out'), 1000);
                }
            } catch (err) {
                console.error("Error al guardar progreso:", err);
            }
        }

        if (btnGuardar) btnGuardar.addEventListener('click', saveProgress);
        if (inputPagina) inputPagina.addEventListener('change', saveProgress);

        function toggleFullScreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen();
            } else {
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                }
            }
        }
        
        // Atajos de teclado
        document.addEventListener('keydown', (e) => {
            if (e.key === 's' && (e.ctrlKey || e.metaKey)) {
                e.preventDefault();
                saveProgress();
            }
        });
    </script>
}
