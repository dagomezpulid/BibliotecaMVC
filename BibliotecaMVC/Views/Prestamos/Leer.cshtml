@model BibliotecaMVC.Models.Libro

@{
    ViewData["Title"] = "Leer Libro";
    
    var primerArchivo = Model.Archivos?.FirstOrDefault();
    var isPdf = primerArchivo?.Formato?.EndsWith("pdf", StringComparison.OrdinalIgnoreCase) ?? false;
    // Extraer el PrestamoId de la URL
    var prestamoId = ViewContext.RouteData.Values["id"];
}

<div class="container-fluid py-4 min-vh-100 d-flex flex-column">
    
    <!-- Barra Superior de Navegación del Visor -->
    <div class="d-flex justify-content-between align-items-center bg-dark text-white p-3 rounded-top-3 shadow">
        <div class="d-flex align-items-center">
            <a asp-controller="Prestamos" asp-action="Index" class="btn btn-outline-light me-3 border-0">
                <i class="bi bi-arrow-left"></i> Volver a Mis Préstamos
            </a>
            <h5 class="mb-0 fw-bold border-start ps-3 py-1 border-secondary">
                <i class="bi bi-book me-2 text-warning"></i>@Model.Titulo
            </h5>
        </div>
        
        <div>
            <a asp-action="DescargarLibro" asp-route-id="@prestamoId" class="btn btn-warning shadow-sm fw-bold px-4 rounded-pill">
                <i class="bi bi-download me-2"></i>Descargar Copia
            </a>
        </div>
    </div>

    <!-- Contenedor Principal del Lector -->
    <div class="bg-light flex-grow-1 p-0 m-0 rounded-bottom-3 shadow d-flex align-items-stretch" style="min-height: 80vh;">
        
        @if (isPdf)
        {
            <!-- Visor de PDF Nativo via DRM Stream -->
            <iframe src="/Prestamos/ArchivoLectura/@prestamoId#toolbar=0" 
                    title="Visor de PDF de @Model.Titulo"
                    class="w-100 border-0 rounded-bottom-3" 
                    style="min-height: 80vh; height: 100%; display: block;"
                    allowfullscreen>
            </iframe>
        }
        else
        {
            <!-- Formatos No Soportados en Pantalla (Word/EPUB) -->
            <div class="w-100 d-flex flex-column justify-content-center align-items-center text-center p-5">
                <div class="bg-white p-5 rounded-4 shadow-sm border" style="max-width: 600px;">
                    <span class="display-1 text-primary opacity-75 mb-4 d-block">
                        <i class="bi bi-file-earmark-text"></i>
                    </span>
                    <h3 class="fw-bold text-dark">Lector no nativo requerido</h3>
                    <p class="text-muted fs-5 mt-3 mb-4">
                        El libro digital de "<strong>@Model.Titulo</strong>" se encuentra en un formato que tu navegador no puede reproducir directamente en pantalla (Ej. Word o EPUB).
                    </p>
                    <p class="text-secondary small mb-4">
                        Pero no te preocupes, puedes descargar el archivo íntegro y leerlo usando la aplicación correspondiente en tu dispositivo. Tu licencia sigue activa.
                    </p>
                    
                    <a asp-action="DescargarLibro" asp-route-id="@prestamoId" class="btn btn-primary btn-lg fw-bold px-5 py-3 rounded-pill shadow">
                        <i class="bi bi-cloud-download me-2"></i>Descargar para Leer Offline
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Ocultar el layout principal si queremos una experiencia inmersiva */
    header, footer {
        display: none !important;
    }
    main {
        padding: 0 !important;
        margin: 0 !important;
    }
    body {
        background-color: #f8f9fa;
    }
</style>
