@model IEnumerable<BibliotecaMVC.Models.Libro>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 fade-in">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card book-card shadow-sm rounded-4 border-0">
                    <div class="book-cover-container bg-light position-relative">
                        @if (!string.IsNullOrEmpty(item.ImagenUrl))
                        {
                            <img src="@item.ImagenUrl" class="book-cover" alt="@item.Titulo" onerror="this.src='https://placehold.co/400x600?text=Sin+Portada'">
                        }
                        else
                        {
                            <div class="text-center p-4">
                                <span class="display-1 text-muted opacity-25">📖</span>
                            </div>
                        }
                        
                        @* Overlay de Calificación Promedio *@
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-white text-dark shadow-sm rounded-pill px-2 py-1 border border-light">
                                <span class="text-warning">★</span> @item.RatingPromedio
                            </span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column p-4">
                        <div class="mb-2">
                            @if (item.Categorias != null && item.Categorias.Any())
                            {
                                foreach (var cat in item.Categorias)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill category-badge">@cat.Nombre</span>
                                }
                            }
                        </div>
                        
                        <h5 class="card-title fw-bold text-dark mb-1 text-truncate" title="@item.Titulo">@item.Titulo</h5>
                        <p class="text-muted small mb-3">
                            <span class="me-1">✍️</span> @(item.Autor?.Nombre ?? "Autor desconocido")
                        </p>

                        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                            <div class="small">
                                @if(item.Stock > 0)
                                {
                                    <span class="text-success fw-semibold">● @item.Stock Disp.</span>
                                }
                                else
                                {
                                    <span class="text-danger fw-semibold">○ Agotado</span>
                                }
                            </div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark rounded-pill px-3">Ver detalles</a>
                        </div>

                        <div class="mt-3">
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="btn-group w-100">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border py-2">Editar</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-dark py-2">Administrar</a>
                                </div>
                            }
                            else
                            {
                                <a asp-controller="Prestamos" asp-action="ConfirmarPrestamo" asp-route-id="@item.Id" 
                                   class="btn btn-primary w-100 rounded-pill shadow-sm py-2 @(item.Stock <= 0 ? "disabled" : "")">
                                    📖 Solicitar Préstamo
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 py-5 text-center">
            <div class="bg-light rounded-4 border border-dashed p-5">
                <span class="display-1">🏜️</span>
                <h3 class="mt-3 text-muted">Sin coincidencias</h3>
                <p class="text-muted">No encontramos libros que coincidan con tu búsqueda.</p>
                <button type="button" onclick="resetSearch()" class="btn btn-outline-primary rounded-pill mt-2">Ver todo el catálogo</button>
            </div>
        </div>
    }
</div>
