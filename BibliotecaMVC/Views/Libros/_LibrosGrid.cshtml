@model IEnumerable<BibliotecaMVC.Models.Libro>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 fade-in">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card book-card shadow-sm rounded-4 border-0 h-100 bg-white hover-up overflow-hidden">
                    <div class="book-cover-container bg-light position-relative overflow-hidden" style="height: 280px;">
                        @if (!string.IsNullOrEmpty(item.ImagenUrl))
                        {
                            <img src="@item.ImagenUrl" class="book-cover w-100 h-100 object-fit-cover transition" alt="@item.Titulo" onerror="this.src='https://placehold.co/400x600?text=Sin+Portada'">
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 bg-gradient opacity-75" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                                <span class="display-3 opacity-25">📖</span>
                            </div>
                        }
                        
                        @* Botón de Favorito *@
                        <div class="position-absolute top-0 start-0 m-3 z-3">
                            <button type="button" 
                                    class="btn bg-white bg-opacity-75 shadow-sm rounded-pill p-2 border-0 fav-btn" 
                                    data-libro-id="@item.Id"
                                    title="@(item.EsFavorito ? "Quitar de favoritos" : "Agregar a favoritos")">
                                <span class="heart-icon fs-5 @(item.EsFavorito ? "text-danger" : "text-muted")">
                                    @(item.EsFavorito ? "❤️" : "🤍")
                                </span>
                            </button>
                        </div>

                        @* Overlay de Calificación Promedio *@
                        <div class="position-absolute top-0 end-0 m-3 z-3">
                            <span class="badge bg-white bg-opacity-75 text-dark shadow-sm rounded-pill px-2 py-1 border border-light">
                                <span class="text-warning">★</span> @item.RatingPromedio
                            </span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column p-3">
                        <div class="mb-2 d-flex flex-wrap gap-1">
                            @if (item.Categorias != null && item.Categorias.Any())
                            {
                                foreach (var cat in item.Categorias)
                                {
                                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10" style="font-size: 0.7rem;">@cat.Nombre</span>
                                }
                            }
                        </div>
                        
                        <h6 class="card-title fw-bold text-dark mb-1 text-truncate" title="@item.Titulo">@item.Titulo</h6>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-person-pencil me-1"></i> @(item.Autor?.Nombre ?? "Autor desconocido")
                        </p>

                        <div class="mt-auto pt-2 border-top d-flex justify-content-between align-items-center">
                            <div class="small">
                                @if(item.Archivos != null && item.Archivos.Any())
                                {
                                    <span class="text-success fw-semibold" style="font-size: 0.8rem;"><i class="bi bi-check2-circle"></i> Digital</span>
                                }
                                else
                                {
                                    <span class="text-muted opacity-50 fw-semibold" style="font-size: 0.8rem;"><i class="bi bi-x-circle"></i> Físico</span>
                                }
                            </div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-primary text-decoration-none small fw-bold">Ver más</a>
                        </div>

                        <div class="mt-3">
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="btn-group w-100 shadow-sm rounded-pill overflow-hidden">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border-end py-2">Editar</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-dark py-2">Admin</a>
                                </div>
                            }
                            else
                            {
                                <a asp-controller="Prestamos" asp-action="ConfirmarPrestamo" asp-route-id="@item.Id" 
                                   class="btn btn-primary w-100 rounded-pill shadow-sm py-2 fw-bold @(!(item.Archivos?.Any() ?? false) ? "disabled" : "")">
                                    <i class="bi bi-bookmark-plus-fill me-1"></i> Prestar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 py-5 text-center">
            <div class="bg-light rounded-4 border border-dashed p-5">
                <span class="display-1">🏜️</span>
                <h3 class="mt-3 text-muted fw-bold">Sin coincidencias</h3>
                <p class="text-muted">No encontramos libros que coincidan con tu búsqueda.</p>
                <button type="button" onclick="resetSearch()" class="btn btn-outline-primary rounded-pill mt-2 px-4 shadow-sm">Ver todo el catálogo</button>
            </div>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-5 pb-3">
        <ul class="pagination justify-content-center gap-2">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <button class="page-link rounded-pill px-4 shadow-sm border-0 fw-bold @(i == ViewBag.CurrentPage ? "bg-primary text-white" : "bg-white text-primary")" 
                            onclick="changePage(@i)">
                        @i
                    </button>
                </li>
            }
        </ul>
    </nav>
}

<script>
    // Delegación de eventos para los botones de favoritos (funciona tras refrescos AJAX)
    if (typeof initFavoritesSet === 'undefined') {
        window.initFavoritesSet = true;
        document.addEventListener('click', function(e) {
            const btn = e.target.closest('.fav-btn');
            if (!btn) return;

            const libroId = btn.getAttribute('data-libro-id');
            const icon = btn.querySelector('.heart-icon');

            fetch(`/Favoritos/Toggle?libroId=${libroId}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (data.esFavorito) {
                        icon.innerHTML = '❤️';
                        icon.classList.remove('text-muted');
                        icon.classList.add('text-danger');
                        btn.title = 'Quitar de favoritos';
                    } else {
                        icon.innerHTML = '🤍';
                        icon.classList.remove('text-danger');
                        icon.classList.add('text-muted');
                        btn.title = 'Agregar a favoritos';
                    }
                }
            })
            .catch(err => console.error('Error al toggle de favorito:', err));
        });
    }
</script>
