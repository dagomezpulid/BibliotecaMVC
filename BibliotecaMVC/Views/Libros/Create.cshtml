@model BibliotecaMVC.Models.Libro

@{
    ViewData["Title"] = "Nuevo Libro";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow rounded-4 border-0">
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h3 class="fw-bold mb-0">📖 Registrar Nuevo Libro</h3>
                    <p class="mb-0 text-white-50">Completa la información técnica y visual del catálogo</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <!-- Sección Principal -->
                            <div class="col-md-12">
                                <label asp-for="Titulo" class="form-label fw-semibold text-dark">Título del Libro</label>
                                <input asp-for="Titulo" class="form-control form-control-lg rounded-3" placeholder="Ej: Rayuela" />
                                <span asp-validation-for="Titulo" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="AutorId" class="form-label fw-semibold text-dark">Autor</label>
                                <select asp-for="AutorId" class="form-select rounded-3" asp-items="ViewBag.Autores">
                                    <option value="">-- Seleccionar Autor --</option>
                                </select>
                                <span asp-validation-for="AutorId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Stock" class="form-label fw-semibold text-dark">Stock Inicial</label>
                                <input asp-for="Stock" class="form-control rounded-3" type="number" min="0" />
                                <span asp-validation-for="Stock" class="text-danger small"></span>
                            </div>

                            <!-- Metadatos Avanzados -->
                            <hr class="my-4 text-muted border-top border-opacity-10">
                            
                            <div class="col-md-6">
                                <label asp-for="ISBN" class="form-label fw-semibold text-dark">ISBN</label>
                                <div class="input-group">
                                    <input asp-for="ISBN" id="isbnInput" class="form-control rounded-start-3" placeholder="978-XXXXXXXXXX" />
                                    <button type="button" id="btnLookup" class="btn btn-dark rounded-end-3 px-3">
                                        <span id="lookupSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                                        <span id="lookupText">✨ Autocompletar</span>
                                    </button>
                                </div>
                                <span asp-validation-for="ISBN" class="text-danger small"></span>
                                <small class="text-muted d-block mt-1">Ingresa el ISBN para buscar datos en Google Books.</small>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Categorías</label>
                                <select name="CategoriasSeleccionadas" class="form-select rounded-3" multiple size="4" asp-items="ViewBag.Categorias">
                                </select>
                                <p class="text-muted small mt-1"><i class="bi bi-info-circle me-1"></i>Manten presionado Ctrl para seleccionar varias.</p>
                            </div>

                            <div class="col-12">
                                <label asp-for="ImagenUrl" class="form-label fw-semibold text-dark">URL de la Portada</label>
                                <div class="input-group">
                                    <input asp-for="ImagenUrl" id="imageUrlInput" class="form-control rounded-3" placeholder="https://ejemplo.com/portada.jpg" />
                                </div>
                                <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Descripcion" class="form-label fw-semibold text-dark">Descripción / Sinopsis</label>
                                <textarea asp-for="Descripcion" id="descriptionInput" class="form-control rounded-3" rows="4" placeholder="Breve resumen del libro..."></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a asp-action="Index" class="btn btn-light px-4 rounded-pill border">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow">Guardar Libro</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.getElementById('btnLookup').addEventListener('click', function() {
            const isbn = document.getElementById('isbnInput').value.replace(/-/g, '').trim();
            if (!isbn) {
                alert('Por favor ingress un ISBN válido.');
                return;
            }

            const btn = this;
            const spinner = document.getElementById('lookupSpinner');
            const text = document.getElementById('lookupText');

            btn.disabled = true;
            spinner.classList.remove('d-none');
            text.textContent = ' Buscando...';

            fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}`)
                .then(response => response.json())
                .then(data => {
                    if (data.totalItems > 0) {
                        const info = data.items[0].volumeInfo;
                        
                        // Autocompletar campos
                        document.querySelector('input[name="Titulo"]').value = info.title || '';
                        document.getElementById('descriptionInput').value = info.description || '';
                        
                        if (info.imageLinks && info.imageLinks.thumbnail) {
                            // Usamos HTTPS y evitamos la versión pequeña si es posible
                            let url = info.imageLinks.thumbnail.replace('http:', 'https:');
                            document.getElementById('imageUrlInput').value = url;
                        }

                        // Notificación visual de éxito (Toast o Alerta simple)
                        alert('✨ ¡Datos encontrados! El formulario se ha completado automáticamente.');
                    } else {
                        alert('❌ No se encontró información para este ISBN en Google Books.');
                    }
                })
                .catch(error => {
                    console.error('Error fetching Google Books:', error);
                    alert('⚠️ Error al conectar con Google Books.');
                })
                .finally(() => {
                    btn.disabled = false;
                    spinner.classList.add('d-none');
                    text.textContent = ' Autocompletar';
                });
        });
    </script>
}
