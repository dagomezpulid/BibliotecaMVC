@model BibliotecaMVC.Models.Libro

@{
    ViewData["Title"] = "Nuevo Libro";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow rounded-4 border-0">
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h3 class="fw-bold mb-0">📖 Registrar Nuevo Libro</h3>
                    <p class="mb-0 text-white-50">Completa la información técnica y visual del catálogo</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <!-- Sección Principal -->
                            <div class="col-md-12">
                                <label asp-for="Titulo" class="form-label fw-semibold text-dark">Título del Libro</label>
                                <input asp-for="Titulo" id="tituloInput" class="form-control form-control-lg rounded-3" placeholder="Ej: Rayuela" />
                                <span asp-validation-for="Titulo" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="AutorId" class="form-label fw-semibold text-dark">Autor</label>
                                <select asp-for="AutorId" id="autorSelect" class="form-select rounded-3" asp-items="ViewBag.Autores">
                                    <option value="">-- Seleccionar Autor --</option>
                                </select>
                                <span asp-validation-for="AutorId" class="text-danger small"></span>
                            </div>



                            <hr class="my-4 text-muted border-top border-opacity-10">
                            
                            <!-- Carga Digital del Libro -->
                            <div class="col-12 bg-light p-4 rounded-3 border">
                                <h5 class="fw-bold text-dark"><i class="bi bi-cloud-arrow-up text-primary me-2"></i>Archivo Digital</h5>
                                <p class="text-muted small mb-2">Para una biblioteca 100% virtual, adjunta el contenido digital del libro.</p>
                                <label class="form-label fw-semibold text-dark">Subir Archivos (Soporta múltiples .PDF, .EPUB, .DOC, .DOCX)</label>
                                <input type="file" name="archivosLibro" class="form-control form-control-lg bg-white shadow-sm" accept=".pdf,.epub,.doc,.docx" multiple />
                            </div>

                            <!-- Metadatos Avanzados -->
                            <hr class="my-4 text-muted border-top border-opacity-10">
                            
                            <div class="col-md-6">
                                <label asp-for="ISBN" class="form-label fw-semibold text-dark">ISBN (10 o 13 dígitos)</label>
                                <div class="input-group">
                                    <input asp-for="ISBN" id="isbnInput" class="form-control rounded-start-3" placeholder="Ej: 978..." />
                                    <button type="button" id="btnAutocompletar" class="btn btn-dark rounded-end-3 px-3">
                                        <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                                        <span id="btnText">🪄 Autocompletar</span>
                                    </button>
                                </div>
                                <span asp-validation-for="ISBN" class="text-danger small"></span>
                                <div id="isbnFeedback" class="small mt-1 px-2 d-none"></div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Categorías</label>
                                <select name="CategoriasSeleccionadas" id="categoriaSelect" class="form-select rounded-3" multiple size="4" asp-items="ViewBag.Categorias">
                                </select>
                                <p class="text-muted small mt-1"><i class="bi bi-info-circle me-1"></i>Ctrl + Click para selección múltiple.</p>
                            </div>

                            <div class="col-12">
                                <label asp-for="ImagenUrl" class="form-label fw-semibold text-dark">URL de la Portada</label>
                                <input asp-for="ImagenUrl" id="imagenInput" class="form-control rounded-3" placeholder="https://ejemplo.com/portada.jpg" />
                                <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Descripcion" class="form-label fw-semibold text-dark">Descripción / Sinopsis</label>
                                <textarea asp-for="Descripcion" id="descripcionInput" class="form-control rounded-3" rows="4" placeholder="Breve resumen del libro..."></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a asp-action="Index" class="btn btn-light px-4 rounded-pill border">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow">Guardar Libro</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.getElementById('btnAutocompletar').addEventListener('click', async function() {
            const rawIsbn = document.getElementById('isbnInput').value;
            const isbn = rawIsbn.replace(/[^0-9Xx]/g, '').toUpperCase();
            const btn = this;
            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const feedback = document.getElementById('isbnFeedback');

            if (!isbn || isbn.length < 10) {
                showFeedback("⚠️ Ingresa un ISBN válido para buscar.", "text-danger");
                return;
            }

            // Estados de UI
            btn.disabled = true;
            btnText.innerText = "Buscando...";
            btnSpinner.classList.remove('d-none');
            feedback.classList.add('d-none');

            try {
                const bookData = await buscarLibroMultiService(isbn);

                if (bookData) {
                    fillIfEmpty('tituloInput', bookData.titulo);
                    
                    if (bookData.descripcion) {
                        const cleanDesc = bookData.descripcion.replace(/<\/?[^>]+(>|$)/g, "");
                        fillIfEmpty('descripcionInput', cleanDesc);
                    }

                    if (bookData.imagenUrl) {
                        fillIfEmpty('imagenInput', bookData.imagenUrl);
                    }

                    if (bookData.autor) {
                        matchInSelect('autorSelect', bookData.autor);
                    }

                    if (bookData.categorias && bookData.categorias.length > 0) {
                        bookData.categorias.forEach(cat => matchInSelect('categoriaSelect', cat, true));
                    }

                    showFeedback(`✨ Datos recuperados vía ${bookData.source}.`, "text-success");
                } else {
                    showFeedback("❌ No se encontraron datos en Google Books ni OpenLibrary.", "text-warning");
                }
            } catch (error) {
                console.error("Error ISBN Search:", error);
                showFeedback("⚠️ Error de conexión con los servicios de búsqueda.", "text-danger");
            } finally {
                btn.disabled = false;
                btnText.innerText = "🪄 Autocompletar";
                btnSpinner.classList.add('d-none');
            }
        });

        async function buscarLibroMultiService(isbn) {
            // 1. INTENTAR GOOGLE BOOKS (Prioridad por riqueza de datos)
            try {
                console.log("Consultando Google Books...");
                let response = await fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}`);
                if (response.ok) {
                    let data = await response.json();
                    if (data.totalItems > 0) return { ...mapearGoogle(data.items[0]), source: "Google Books" };
                }
                
                // Búsqueda general en Google si la específica falla
                response = await fetch(`https://www.googleapis.com/books/v1/volumes?q=${isbn}`);
                if (response.ok) {
                    let data = await response.json();
                    if (data.totalItems > 0) return { ...mapearGoogle(data.items[0]), source: "Google Books" };
                }
            } catch (e) { console.warn("Google Books falló o alcanzó cuota."); }

            // 2. FALLBACK A OPEN LIBRARY
            try {
                console.log("Consultando OpenLibrary...");
                let response = await fetch(`https://openlibrary.org/api/books?bibkeys=ISBN:${isbn}&format=json&jscmd=data`);
                if (response.ok) {
                    let data = await response.json();
                    const key = `ISBN:${isbn}`;
                    if (data[key]) return { ...mapearOpenLibrary(data[key]), source: "OpenLibrary" };
                }
            } catch (e) { console.warn("OpenLibrary falló."); }

            return null;
        }

        function mapearGoogle(item) {
            const info = item.volumeInfo;
            let bestUrl = null;
            if (info.imageLinks) {
                const sizes = ['extraLarge', 'large', 'medium', 'small', 'thumbnail', 'smallThumbnail'];
                for (const size of sizes) {
                    if (info.imageLinks[size]) {
                        bestUrl = info.imageLinks[size].replace("http://", "https://");
                        break;
                    }
                }
            }
            return {
                titulo: info.title,
                descripcion: info.description || (item.searchInfo ? item.searchInfo.textSnippet : ""),
                imagenUrl: bestUrl,
                autor: info.authors ? info.authors[0] : null,
                categorias: info.categories || []
            };
        }

        function mapearOpenLibrary(book) {
            return {
                titulo: book.title,
                descripcion: book.notes || (book.excerpts ? book.excerpts[0].text : ""),
                imagenUrl: book.cover ? (book.cover.large || book.cover.medium || book.cover.small) : null,
                autor: book.authors ? book.authors[0].name : null,
                categorias: book.subjects ? book.subjects.map(s => s.name) : []
            };
        }

        function fillIfEmpty(elementId, value) {
            const el = document.getElementById(elementId);
            if (el && value && (!el.value || el.value.trim() === "")) {
                el.value = value;
            }
        }

        function matchInSelect(selectId, searchText, isMultiple = false) {
            const select = document.getElementById(selectId);
            if (!select) return;
            const search = searchText.toLowerCase();
            let found = false;
            for (let i = 0; i < select.options.length; i++) {
                const optText = select.options[i].text.toLowerCase();
                if (optText.includes(search) || search.includes(optText)) {
                    if (isMultiple) {
                        select.options[i].selected = true;
                    } else if (!found) {
                        select.selectedIndex = i;
                        found = true;
                    }
                }
            }
        }

        function showFeedback(message, cssClass) {
            const feedback = document.getElementById('isbnFeedback');
            feedback.innerText = message;
            feedback.className = `small mt-1 px-2 ${cssClass}`;
            feedback.classList.remove('d-none');
        }
    </script>
}
