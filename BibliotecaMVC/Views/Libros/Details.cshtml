@model BibliotecaMVC.Models.Libro
@{
    ViewData["Title"] = Model.Titulo;
}

<style>
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }
    .star-rating input {
        display: none;
    }
    .star-rating label {
        color: #ddd;
        font-size: 2rem;
        padding: 0 0.1em;
        cursor: pointer;
        transition: color 0.2s ease;
    }
    .star-rating input:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label {
        color: #ffc107;
    }
    .review-card {
        border-left: 4px solid #0d6efd;
        background: #f8f9fa;
    }
    .star-filled { color: #ffc107; }
    .star-empty { color: #ddd; }
</style>

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Catálogo</a></li>
            <li class="breadcrumb-item active" aria-current="page">Detalles del Libro</li>
        </ol>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4" role="alert">
            <strong>✨ ¡Excelente!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4" role="alert">
            <strong>⚠️ Atención:</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden mb-5">
        <div class="row g-0">
            <div class="col-md-4 bg-light d-flex align-items-center justify-content-center p-4 border-end">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="img-fluid rounded-3 shadow" alt="@Model.Titulo" style="max-height: 500px; width: auto;">
                }
                else
                {
                    <div class="text-center py-5">
                        <span class="display-1 text-muted">📖</span>
                        <p class="text-muted mt-2">Sin imagen de portada</p>
                    </div>
                }
            </div>
            <div class="col-md-8">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            @if (Model.Categorias != null && Model.Categorias.Any())
                            {
                                foreach (var cat in Model.Categorias)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 me-1">@cat.Nombre</span>
                                }
                            }
                            <h1 class="display-5 fw-bold text-dark mt-2 mb-1">@Model.Titulo</h1>
                            <div class="d-flex align-items-center mb-2">
                                <div class="me-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="fs-4 @(i <= Math.Round(Model.RatingPromedio) ? "star-filled" : "star-empty")">★</span>
                                    }
                                </div>
                                <span class="fw-bold fs-5">@Model.RatingPromedio</span>
                                <span class="text-muted ms-2">(@Model.Resenas.Count reseñas)</span>
                            </div>
                            <p class="fs-4 text-muted">por <span class="text-dark fw-semibold">@(Model.Autor?.Nombre)</span></p>
                        </div>
                        <div class="text-end">
                            @if (Model.Stock > 0)
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">Disponible: @Model.Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-2">Agotado</span>
                            }
                        </div>
                    </div>

                    <div class="mt-4 mb-5">
                        <h5 class="fw-bold text-dark border-bottom pb-2">Sinopsis</h5>
                        <p class="text-muted lh-lg">
                            @(string.IsNullOrEmpty(Model.Descripcion) ? "No hay una descripción disponible para este libro aún." : Model.Descripcion)
                        </p>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-6 col-sm-4">
                            <div class="p-3 bg-light rounded-3 text-center">
                                <small class="text-muted d-block mb-1">ISBN</small>
                                <span class="fw-bold text-dark">@(string.IsNullOrEmpty(Model.ISBN) ? "N/A" : Model.ISBN)</span>
                            </div>
                        </div>
                        <div class="col-6 col-sm-4">
                            <div class="p-3 bg-light rounded-3 text-center">
                                <small class="text-muted d-block mb-1">ID Sistema</small>
                                <span class="fw-bold text-dark">#@Model.Id</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        @if (!User.IsInRole("Admin"))
                        {
                            <a asp-controller="Prestamos" asp-action="ConfirmarPrestamo" asp-route-id="@Model.Id" 
                               class="btn btn-primary btn-lg rounded-pill px-5 shadow @(Model.Stock <= 0 ? "disabled" : "")">
                                Solicitar Préstamo
                            </a>
                        }
                        else
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark btn-lg rounded-pill px-5 shadow">
                                Editar Datos
                            </a>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">Volver al Catálogo</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- SECCIÓN DE RESEÑAS --- *@
    <div class="row g-5">
        <div class="col-lg-7">
            <h3 class="fw-bold mb-4">Comentarios de Lectores</h3>
            @if (Model.Resenas != null && Model.Resenas.Any())
            {
                foreach (var resena in Model.Resenas.OrderByDescending(r => r.FechaPublicacion))
                {
                    <div class="card review-card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px; font-weight: bold;">
                                    @(resena.Usuario?.Nombre?.Substring(0, 1) ?? "U")
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@(resena.Usuario?.NombreCompleto ?? "Usuario de la Biblioteca")</h6>
                                    <small class="text-muted">@resena.FechaPublicacion.ToString("dd MMM yyyy, hh:mm tt")</small>
                                </div>
                            </div>
                            <div class="text-warning fs-5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>@(i <= resena.Puntuacion ? "★" : "☆")</span>
                                }
                            </div>
                        </div>
                        <p class="text-dark mb-0 italic">"@resena.Comentario"</p>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-light rounded-4 border border-dashed">
                    <p class="text-muted mb-0">Nadie ha calificado este libro todavía. ¡Sé el primero!</p>
                </div>
            }
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow rounded-4 p-4 sticky-top" style="top: 2rem;">
                <h4 class="fw-bold mb-3">Deja tu opinión</h4>
                <form asp-action="PostResena" method="post">
                    <input type="hidden" name="LibroId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tu Calificación</label>
                        <div class="star-rating">
                            <input type="radio" id="star5" name="Puntuacion" value="5" required /><label for="star5" title="5 estrellas">★</label>
                            <input type="radio" id="star4" name="Puntuacion" value="4" /><label for="star4" title="4 estrellas">★</label>
                            <input type="radio" id="star3" name="Puntuacion" value="3" /><label for="star3" title="3 estrellas">★</label>
                            <input type="radio" id="star2" name="Puntuacion" value="2" /><label for="star2" title="2 estrellas">★</label>
                            <input type="radio" id="star1" name="Puntuacion" value="1" /><label for="star1" title="1 estrella">★</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tu Comentario</label>
                        <textarea name="Comentario" class="form-control rounded-3" rows="4" placeholder="¿Qué te pareció el libro? Comparte tu experiencia..." required minlength="10"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 shadow-sm fw-bold">
                        Publicar Reseña
                    </button>
                    <p class="text-muted small mt-3 text-center">
                        <i class="bi bi-shield-check"></i> Tu opinión ayuda a otros lectores a elegir su próxima historia.
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>
