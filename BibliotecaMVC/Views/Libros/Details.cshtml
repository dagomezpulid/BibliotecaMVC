@model BibliotecaMVC.Models.Libro
@{
    ViewData["Title"] = Model.Titulo;
}

<style>
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }
    .star-rating input {
        display: none;
    }
    .star-rating label {
        color: #ddd;
        font-size: 2rem;
        padding: 0 0.1em;
        cursor: pointer;
        transition: color 0.2s ease;
    }
    .star-rating input:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label {
        color: #ffc107;
    }
    .review-card {
        border-left: 5px solid #0d6efd;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        transition: transform 0.3s ease;
    }
    .review-card:hover { transform: translateX(5px); }
    .star-filled { color: #ffc107; }
    .star-empty { color: #ddd; }

    /* Carousel Styles */
    .recommendations-wrapper {
        position: relative;
        overflow: hidden;
        padding: 20px 0;
    }
    .recommendations-scroll {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        scroll-behavior: smooth;
        scrollbar-width: none; /* Firefox */
        padding-bottom: 20px;
    }
    .recommendations-scroll::-webkit-scrollbar { display: none; } /* Chrome/Safari */
    
    .recommended-card {
        min-width: 200px;
        max-width: 200px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }
    .recommended-card:hover {
        transform: translateY(-10px);
    }
    .carousel-control-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        z-index: 10;
        cursor: pointer;
        border: none;
    }
    .carousel-control-btn.prev { left: 0; }
    .carousel-control-btn.next { right: 0; }
</style>

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Catálogo</a></li>
            <li class="breadcrumb-item active" aria-current="page">Detalles del Libro</li>
        </ol>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4" role="alert">
            <strong>✨ ¡Excelente!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4" role="alert">
            <strong>⚠️ Atención:</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden mb-5">
        <div class="row g-0">
            <div class="col-md-4 bg-light d-flex align-items-center justify-content-center p-4 border-end">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="img-fluid rounded-3 shadow" alt="@Model.Titulo" style="max-height: 500px; width: auto;">
                }
                else
                {
                    <div class="text-center py-5">
                        <span class="display-1 text-muted">📖</span>
                        <p class="text-muted mt-2">Sin imagen de portada</p>
                    </div>
                }
            </div>
            <div class="col-md-8">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            @if (Model.Categorias != null && Model.Categorias.Any())
                            {
                                foreach (var cat in Model.Categorias)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 me-1">@cat.Nombre</span>
                                }
                            }
                            <h1 class="display-5 fw-bold text-dark mt-2 mb-1">@Model.Titulo</h1>
                            <div class="d-flex align-items-center mb-2">
                                <div class="me-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="fs-4 @(i <= Math.Round(Model.RatingPromedio) ? "star-filled" : "star-empty")">★</span>
                                    }
                                </div>
                                <span class="fw-bold fs-5">@Model.RatingPromedio</span>
                                <span class="text-muted ms-2">(@(Model.Resenas?.Count ?? 0) reseñas)</span>
                            </div>
                            <p class="fs-4 text-muted">por <span class="text-dark fw-semibold">@(Model.Autor?.Nombre ?? "Autor Desconocido")</span></p>
                        </div>
                        <div class="text-end">
                            @if (Model.Archivos != null && Model.Archivos.Any())
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-cloud-check-fill me-1"></i> Disponible Digital</span>
                            }
                            else
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-cloud-slash-fill me-1"></i> Sin Copias Digitales</span>
                            }
                        </div>
                    </div>

                    <div class="mt-4 mb-5">
                        <div class="d-flex align-items-center mb-2">
                            <h5 class="fw-bold text-dark mb-0 me-2">Sinopsis</h5>
                            <span id="externalBadge" class="badge bg-info text-white d-none" style="font-size: 0.6rem;">Enriquecido con Fuentes Externas</span>
                        </div>
                        <p id="bookDescription" class="text-muted lh-lg">
                            @(string.IsNullOrEmpty(Model.Descripcion) ? "No hay una descripción disponible para este libro aún." : Model.Descripcion)
                        </p>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-6 col-sm-4">
                            <div class="p-3 bg-light rounded-3 text-center">
                                <small class="text-muted d-block mb-1">ISBN</small>
                                <span class="fw-bold text-dark">@(string.IsNullOrEmpty(Model.ISBN) ? "N/A" : Model.ISBN)</span>
                            </div>
                        </div>
                        <div class="col-6 col-sm-4">
                            <div class="p-3 bg-light rounded-3 text-center">
                                <small class="text-muted d-block mb-1">ID Sistema</small>
                                <span class="fw-bold text-dark">#@Model.Id</span>
                            </div>
                        </div>
                    </div>

                    @* Listado de Formatos Disponibles *@
                    <div class="mb-5">
                        <h6 class="fw-bold text-dark mb-3"><i class="bi bi-file-earmark-arrow-down me-2"></i>Formatos Disponibles:</h6>
                        <div class="d-flex flex-wrap gap-2">
                            @if (Model.Archivos != null && Model.Archivos.Any())
                            {
                                foreach (var archivo in Model.Archivos)
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border px-3 py-2">
                                        <i class="bi bi-filetype-@(archivo.Formato?.TrimStart('.').ToLower()) me-1"></i> 
                                        Versión @archivo.Formato?.ToUpper()
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small italic">Aún no se han subido copias digitales para este título.</span>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        @if (!User.IsInRole("Admin"))
                        {
                            <a asp-controller="Prestamos" asp-action="ConfirmarPrestamo" asp-route-id="@Model.Id" 
                               class="btn btn-primary btn-lg rounded-pill px-5 shadow @((Model.Archivos == null || !Model.Archivos.Any()) ? "disabled" : "")">
                                Solicitar Préstamo
                            </a>
                        }
                        else
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark btn-lg rounded-pill px-5 shadow">
                                Editar Datos
                            </a>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">Volver al Catálogo</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- SECCIÓN DE RESEÑAS (MODERNIZADA FASE 4) --- *@
    <div class="row g-5 mt-5">
        <div class="col-lg-7">
            <h3 class="fw-bold mb-4">Comentarios de Lectores</h3>
            @if (Model.Resenas != null && Model.Resenas.Any())
            {
                foreach (var resena in Model.Resenas.OrderByDescending(r => r.FechaPublicacion))
                {
                    <div class="card review-card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px; font-weight: bold; font-size: 1.2rem;">
                                    @(resena.Usuario?.Nombre?.Substring(0, 1) ?? "U")
                                </div>
                                <div class="line-height-1">
                                    <h6 class="mb-0 fw-bold text-dark">@(resena.Usuario?.NombreCompleto ?? "Lector de la Biblioteca")</h6>
                                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> @resena.FechaPublicacion.ToString("dd MMM yyyy")</small>
                                </div>
                            </div>
                            <div class="text-warning fs-5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="bi @(i <= resena.Puntuacion ? "bi-star-fill" : "bi-star")"></span>
                                }
                            </div>
                        </div>
                        <div class="bg-light p-3 rounded-3 position-relative">
                            <span class="position-absolute translate-middle-y top-0 start-0 ms-3 badge bg-white text-primary border shadow-sm">
                                <i class="bi bi-chat-quote-fill"></i> Reseña
                            </span>
                            <p class="text-dark mb-0 mt-2 fst-italic">"@resena.Comentario"</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-white rounded-4 border border-dashed shadow-sm">
                    <span class="display-4 text-muted">💬</span>
                    <p class="text-muted mt-3 mb-0">Nadie ha calificado este libro todavía. ¡Sé el primero en compartir tu experiencia!</p>
                </div>
            }
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 sticky-top overflow-hidden" style="top: 2rem;">
                <div class="position-absolute top-0 end-0 p-3 opacity-10">
                    <i class="bi bi-pencil-square display-1"></i>
                </div>
                <h4 class="fw-bold mb-3">¿Qué te pareció?</h4>
                <p class="text-muted small mb-4">Tu calificación ayuda a otros lectores a descubrir nuevas historias.</p>
                
                <form asp-action="PostResena" method="post">
                    <input type="hidden" name="LibroId" value="@Model.Id" />
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Tu Calificación</label>
                        <div class="star-rating">
                            <input type="radio" id="star5" name="Puntuacion" value="5" required /><label for="star5" title="5 estrellas">★</label>
                            <input type="radio" id="star4" name="Puntuacion" value="4" /><label for="star4" title="4 estrellas">★</label>
                            <input type="radio" id="star3" name="Puntuacion" value="3" /><label for="star3" title="3 estrellas">★</label>
                            <input type="radio" id="star2" name="Puntuacion" value="2" /><label for="star2" title="2 estrellas">★</label>
                            <input type="radio" id="star1" name="Puntuacion" value="1" /><label for="star1" title="1 estrella">★</label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Tu Comentario</label>
                        <textarea name="Comentario" class="form-control rounded-3 border-0 bg-light p-3" rows="4" placeholder="Cuéntanos más sobre el libro..." required minlength="10"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 shadow fw-bold transition-all">
                        <i class="bi bi-send-fill me-2"></i>Publicar Reseña
                    </button>
                    <div class="alert alert-info border-0 bg-info bg-opacity-10 rounded-3 mt-4 mb-0 py-2 px-3 small">
                        <i class="bi bi-info-circle-fill me-2"></i>Recuerda que tu opinión debe ser respetuosa y evitar spoilers.
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* --- SECCIÓN DE RECOMENDACIONES (INTELIGENCIA FASE 4) --- *@
@if (ViewBag.Recomendados != null && ((List<BibliotecaMVC.Models.Libro>)ViewBag.Recomendados).Any())
{
    <div class="bg-light py-5 mt-5">
        <div class="container">
            <h3 class="fw-bold mb-4">Quizás te interese...</h3>
            <div class="recommendations-wrapper">
                <button class="carousel-control-btn prev" onclick="scrollCarousel(-1)">
                    <i class="bi bi-chevron-left text-primary"></i>
                </button>
                <div id="recoCarousel" class="recommendations-scroll">
                    @foreach (var reco in (List<BibliotecaMVC.Models.Libro>)ViewBag.Recomendados)
                    {
                        <a asp-action="Details" asp-route-id="@reco.Id" class="text-decoration-none">
                            <div class="card recommended-card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                                @if (!string.IsNullOrEmpty(reco.ImagenUrl))
                                {
                                    <img src="@reco.ImagenUrl" class="card-img-top" alt="@reco.Titulo" style="height: 220px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-secondary bg-opacity-10 d-flex flex-column align-items-center justify-content-center" style="height: 220px;">
                                        <span class="fs-1">📖</span>
                                    </div>
                                }
                                <div class="card-body p-3">
                                    <h6 class="text-dark fw-bold mb-1 text-truncate">@reco.Titulo</h6>
                                    <small class="text-muted d-block mb-2">@reco.Autor?.Nombre</small>
                                    <div class="text-warning small">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span>@(i <= Math.Round(reco.RatingPromedio) ? "★" : "☆")</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
                <button class="carousel-control-btn next" onclick="scrollCarousel(1)">
                    <i class="bi bi-chevron-right text-primary"></i>
                </button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // LUIS: Enriquecimiento dinámico Multi-Servicio (MEJORADO)
        document.addEventListener("DOMContentLoaded", async function() {
            let isbnRaw = @Html.Raw(Json.Serialize(Model.ISBN));
            const isbn = isbnRaw.replace(/[^0-9Xx]/g, '').toUpperCase();
            
            const descElement = document.getElementById("bookDescription");
            const badge = document.getElementById("externalBadge");

            if (isbn && isbn.length >= 10) {
                try {
                    const info = await buscarInfoLibro(isbn);
                    if (info && info.description && descElement.innerText.length < 150) {
                        descElement.style.opacity = "0";
                        setTimeout(() => {
                            descElement.innerText = info.description;
                            descElement.style.transition = "opacity 0.5s ease";
                            descElement.style.opacity = "1";
                            badge.classList.remove("d-none");
                            badge.innerText = `Enriquecido con ${info.source}`;
                        }, 300);
                    }
                } catch (err) { console.error("Error al enriquecer:", err); }
            }
        });

        async function buscarInfoLibro(isbn) {
            // 1. Google Books
            try {
                let res = await fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}`);
                if (res.ok) {
                    let data = await res.json();
                    if (data.items && data.items.length > 0) {
                        return { description: data.items[0].volumeInfo.description, source: "Google Books" };
                    }
                }
            } catch (e) {}

            // 2. Open Library
            try {
                let res = await fetch(`https://openlibrary.org/api/books?bibkeys=ISBN:${isbn}&format=json&jscmd=data`);
                if (res.ok) {
                    let data = await res.json();
                    const key = `ISBN:${isbn}`;
                    if (data[key]) {
                        return { description: data[key].notes || (data[key].excerpts ? data[key].excerpts[0].text : ""), source: "OpenLibrary" };
                    }
                }
            } catch (e) {}
            return null;
        }

        function scrollCarousel(direction) {
            const carousel = document.getElementById("recoCarousel");
            const scrollAmount = 300;
            carousel.scrollLeft += direction * scrollAmount;
        }
    </script>
}
