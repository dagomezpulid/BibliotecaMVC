@model int

<h2>Prestar Libro</h2>

<p><strong>Libro:</strong> @ViewBag.LibroTitulo</p>

<form asp-controller="Prestamos" asp-action="Prestar" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="libroId" value="@Model" />

    <p>
        La fecha límite de devolución será automática (7 días desde hoy).
    </p>

    <br />

    <button type="submit" class="btn btn-primary">
        Confirmar Préstamo
    </button>

    <a asp-controller="Home"
       asp-action="Index"
       class="btn btn-secondary">
        Cancelar
    </a>
</form>