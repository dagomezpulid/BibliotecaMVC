@model IEnumerable<BibliotecaMVC.Models.Libro>

@{
    ViewData["Title"] = "Catálogo Digital";
}

<style>
    .book-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        overflow: hidden;
        height: 100%;
    }
    .book-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important;
    }
    .book-cover-container {
        height: 350px;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .book-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .category-badge {
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.4em 0.8em;
        margin-right: 4px;
        margin-bottom: 4px;
        display: inline-block;
    }
</style>

<div class="container py-4">
    <div class="row align-items-center mb-5">
        <div class="col-lg-6 mb-3 mb-lg-0">
            <h1 class="fw-bold text-dark mb-1">📚 Explorar Biblioteca</h1>
            <p class="text-muted mb-0">Colección digital actualizada con @Model.Count() títulos</p>
        </div>
        <div class="col-lg-6">
            <div class="position-relative shadow-sm rounded-pill overflow-hidden bg-white border">
                <span class="position-absolute top-50 start-0 translate-middle-y ms-3 text-muted">🔍</span>
                <input type="text" id="searchInput" 
                       class="form-control border-0 ps-5 py-3 rounded-pill" 
                       placeholder="Buscar por título, autor o categoría..." 
                       autocomplete="off">
                <div id="searchSpinner" class="spinner-border spinner-border-sm text-primary position-absolute top-50 end-0 translate-middle-y me-3 d-none" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="text-muted small">
            Mostrando resultados en tiempo real
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
                ➕ Nuevo Libro
            </a>
        }
    </div>

    <div id="resultsContainer">
        @await Html.PartialAsync("_LibrosGrid", Model)
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const resultsContainer = document.getElementById('resultsContainer');
        const spinner = document.getElementById('searchSpinner');
        let timeout = null;

        searchInput.addEventListener('input', function() {
            clearTimeout(timeout);
            spinner.classList.remove('d-none');
            
            timeout = setTimeout(() => {
                const query = searchInput.value;
                
                fetch(`/Libros/Index?query=${encodeURIComponent(query)}`, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    resultsContainer.innerHTML = html;
                    spinner.classList.add('d-none');
                })
                .catch(err => {
                    console.error('Error en búsqueda:', err);
                    spinner.classList.add('d-none');
                });
            }, 500); // 500ms debounce
        });

        function resetSearch() {
            searchInput.value = '';
            searchInput.dispatchEvent(new Event('input'));
        }
    </script>
}
