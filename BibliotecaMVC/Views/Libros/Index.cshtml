@model IEnumerable<BibliotecaMVC.Models.Libro>

@{
    ViewData["Title"] = "Catálogo Digital";
}


<div class="container py-4">
    <div class="row align-items-center mb-5">
        <div class="col-lg-6 mb-3 mb-lg-0">
            <h1 class="fw-bold text-dark mb-1">📚 Explorar Biblioteca</h1>
            <p class="text-muted mb-0">Colección digital actualizada con @Model.Count() títulos</p>
        </div>
        <div class="col-lg-6">
            <div class="position-relative shadow-sm rounded-pill overflow-hidden bg-white border">
                <span class="position-absolute top-50 start-0 translate-middle-y ms-3 text-muted">🔍</span>
                <input type="text" id="searchInput" 
                       class="form-control border-0 ps-5 py-3 rounded-pill" 
                       placeholder="Buscar por título, autor o categoría..." 
                       autocomplete="off">
                <div id="searchSpinner" class="spinner-border spinner-border-sm text-primary position-absolute top-50 end-0 translate-middle-y me-3 d-none" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="text-muted small">
            Mostrando resultados en tiempo real
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary rounded-pill px-4" asp-controller="Admin" asp-action="Index">
                    📊 Volver al Dashboard
                </a>
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
                    ➕ Nuevo Libro
                </a>
            </div>
        }
    </div>

    <div id="resultsContainer">
        @await Html.PartialAsync("_LibrosGrid", Model)
    </div>
</div>

@section Scripts {
<script>
    const searchInput = document.getElementById('searchInput');
    const resultsContainer = document.getElementById('resultsContainer');
    const spinner = document.getElementById('searchSpinner');
    let timeout = null;

    // Función unificada para búsqueda y paginación asíncrona (AJAX)
    async function updateGrid(query = '', page = 1) {
        spinner.classList.remove('d-none');
        try {
            // Construye la URL con los parámetros de filtro y página
            const url = `/Libros/Index?query=${encodeURIComponent(query)}&page=${page}`;
            const response = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const html = await response.text();
            
            // Reemplaza el contenido de la grilla por los nuevos resultados segmentados
            resultsContainer.innerHTML = html;
            
            // UX: Hacer scroll suave hacia arriba al cambiar de página para que el usuario 
            // no pierda el contexto de los nuevos resultados.
            if(page > 1 || query) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        } catch (err) {
            console.error('Error al actualizar grilla:', err);
        } finally {
            spinner.classList.add('d-none');
        }
    }

    // Listener para búsqueda en tiempo real (Debounce de 500ms)
    searchInput.addEventListener('input', function() {
        clearTimeout(timeout);
        timeout = setTimeout(() => {
            updateGrid(searchInput.value, 1);
        }, 500); 
    });

    // Cambia de página manteniendo el filtro de búsqueda actual
    function changePage(page) {
        updateGrid(searchInput.value, page);
    }

    function resetSearch() {
        searchInput.value = '';
        updateGrid('', 1);
    }
</script>
}
