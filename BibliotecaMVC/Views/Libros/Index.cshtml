@model IEnumerable<BibliotecaMVC.Models.Libro>

@{
    ViewData["Title"] = "Catálogo Digital";
}

<style>
    .book-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        overflow: hidden;
        height: 100%;
    }
    .book-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important;
    }
    .book-cover-container {
        height: 350px;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .book-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .category-badge {
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.4em 0.8em;
        margin-right: 4px;
        margin-bottom: 4px;
        display: inline-block;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold text-dark mb-1">📚 Explorar Biblioteca</h1>
            <p class="text-muted mb-0">Colección digital actualizada</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
                <span class="me-2">➕</span> Nuevo Libro
            </a>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card book-card shadow-sm rounded-4">
                        <div class="book-cover-container">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" class="book-cover" alt="@item.Titulo" onerror="this.src='https://placehold.co/400x600?text=Sin+Portada'">
                            }
                            else
                            {
                                <div class="text-center p-4">
                                    <span class="display-1 text-light">📖</span>
                                </div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <div class="mb-2">
                                @if (item.Categorias != null && item.Categorias.Any())
                                {
                                    foreach (var cat in item.Categorias)
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill category-badge">@cat.Nombre</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill category-badge">General</span>
                                }
                            </div>
                            
                            <h5 class="card-title fw-bold text-dark mb-1 text-truncate" title="@item.Titulo">@item.Titulo</h5>
                            <p class="text-muted small mb-3">
                                <span class="me-1">✍️</span> @(item.Autor?.Nombre ?? "Autor desconocido")
                            </p>

                            <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <div class="small">
                                    @if(item.Stock > 0)
                                    {
                                        <span class="text-success fw-semibold">● @item.Stock Disp.</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-semibold">○ Agotado</span>
                                    }
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark rounded-pill px-3">Ver más</a>
                            </div>

                            <div class="mt-3">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group w-100">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border">Editar</a>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="Prestamos" asp-action="ConfirmarPrestamo" asp-route-id="@item.Id" 
                                       class="btn btn-primary w-100 rounded-pill shadow-sm @(item.Stock <= 0 ? "disabled" : "")">
                                        📖 Solicitar Préstamo
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-4 shadow-sm border border-dashed">
            <span class="display-1">🏜️</span>
            <h3 class="mt-3 text-muted">No se encontraron libros</h3>
            <p class="text-muted">La biblioteca está vacía por el momento.</p>
        </div>
    }
</div>
