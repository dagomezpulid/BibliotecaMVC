@model BibliotecaMVC.Models.Libro

@{
    ViewData["Title"] = "Editar Libro";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow rounded-4 border-0">
                <div class="card-header bg-dark text-white p-4 rounded-top-4">
                    <h3 class="fw-bold mb-0">📝 Editar Información</h3>
                    <p class="mb-0 text-white-50">Actualizando "@Model.Titulo"</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="Titulo" class="form-label fw-semibold text-dark">Título</label>
                                <input asp-for="Titulo" class="form-control form-control-lg rounded-3" id="tituloInput" />
                                <span asp-validation-for="Titulo" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="AutorId" class="form-label fw-semibold text-dark">Autor</label>
                                <select asp-for="AutorId" class="form-select rounded-3" id="autorSelect" asp-items="ViewBag.Autores"></select>
                                <span asp-validation-for="AutorId" class="text-danger small"></span>
                            </div>



                            <hr class="my-4 text-muted border-top border-opacity-10">

                            <!-- Carga Digital del Libro -->
                            <div class="col-12 bg-light p-4 rounded-3 border">
                                <h5 class="fw-bold text-dark"><i class="bi bi-cloud-arrow-up text-primary me-2"></i>Gestión de Archivos Digitales</h5>
                                
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-dark">Archivos Actuales:</label>
                                    <div class="list-group rounded-3 mb-2">
                                        @if (Model.Archivos != null && Model.Archivos.Any())
                                        {
                                            foreach (var archivo in Model.Archivos)
                                            {
                                                <div class="list-group-item d-flex justify-content-between align-items-center bg-white">
                                                    <span><i class="bi bi-file-earmark-check text-success me-2"></i>@archivo.Formato?.ToUpper() - @archivo.FechaCarga.ToShortDateString()</span>
                                                    <span class="badge bg-light text-dark border">Activo</span>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="list-group-item text-muted italic">No hay archivos cargados.</div>
                                        }
                                    </div>
                                    <p class="text-muted small"><i class="bi bi-info-circle me-1"></i>Para un sistema 100% digital, puedes añadir más formatos abajo.</p>
                                </div>

                                <label class="form-label fw-semibold text-dark">Añadir Nuevos Archivos (.PDF, .EPUB, .DOC, .DOCX)</label>
                                <input type="file" name="nuevosArchivos" class="form-control form-control-lg bg-white shadow-sm" accept=".pdf,.epub,.doc,.docx" multiple />
                            </div>

                            <hr class="my-4 text-muted border-top border-opacity-10">
                            
                            <div class="col-md-6">
                                <label asp-for="ISBN" class="form-label fw-semibold text-dark">ISBN (10 o 13 dígitos)</label>
                                <div class="input-group">
                                    <input asp-for="ISBN" class="form-control rounded-start-3" id="isbnInput" placeholder="Ej: 978..." />
                                    <button type="button" class="btn btn-primary rounded-end-3 shadow-sm px-3" id="btnAutocompletar" title="Autocomplementar info desde Google Books">
                                        <span id="btnText">🪄 Autocompletar</span>
                                        <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                                    </button>
                                </div>
                                <span asp-validation-for="ISBN" class="text-danger small"></span>
                                <div id="isbnFeedback" class="small mt-1 px-2 d-none"></div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Categorías</label>
                                <select name="CategoriasSeleccionadas" id="categoriaSelect" class="form-select rounded-3" multiple size="4" asp-items="ViewBag.Categorias">
                                </select>
                            </div>

                            <div class="col-12">
                                <label asp-for="ImagenUrl" class="form-label fw-semibold text-dark">URL de la Portada</label>
                                <input asp-for="ImagenUrl" class="form-control rounded-3" id="imagenInput" />
                                <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Descripcion" class="form-label fw-semibold text-dark">Descripción</label>
                                <textarea asp-for="Descripcion" class="form-control rounded-3" id="descripcionInput" rows="4"></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a asp-action="Index" class="btn btn-light px-4 rounded-pill border">Cancelar</a>
                            <button type="submit" class="btn btn-dark px-5 rounded-pill shadow">Guardar Cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.getElementById('btnAutocompletar').addEventListener('click', async function() {
            const isbn = document.getElementById('isbnInput').value.trim();
            const btn = this;
            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const feedback = document.getElementById('isbnFeedback');

            if (!isbn || isbn.length < 10) {
                showFeedback("⚠️ Ingresa un ISBN de 10 o 13 dígitos para buscar.", "text-danger");
                return;
            }

            // Estados de UI
            btn.disabled = true;
            btnText.innerText = "Buscando...";
            btnSpinner.classList.remove('d-none');
            feedback.classList.add('d-none');

            try {
                // 1. Estrategia de Búsqueda Dual (Específica -> General)
                let response = await fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}`);
                let data = await response.json();

                if (data.totalItems === 0) {
                    console.log("ISBN exacto no encontrado, intentando búsqueda persistente...");
                    response = await fetch(`https://www.googleapis.com/books/v1/volumes?q=${isbn}`);
                    data = await response.json();
                }

                if (data.totalItems > 0) {
                    const item = data.items[0];
                    const info = item.volumeInfo;
                    
                    // A. LLENADO CONDICIONAL (Solo si están vacíos)
                    fillIfEmpty('tituloInput', info.title);
                    
                    // Fallback de descripción (Description -> textSnippet)
                    let rawDesc = info.description || (item.searchInfo ? item.searchInfo.textSnippet : "");
                    if (rawDesc) {
                        const cleanDesc = rawDesc.replace(/<\/?[^>]+(>|$)/g, ""); // Limpieza HTML
                        fillIfEmpty('descripcionInput', cleanDesc);
                    }

                    // B. EXTRACCIÓN JERÁRQUICA DE IMAGEN
                    if (info.imageLinks) {
                        const sizes = ['extraLarge', 'large', 'medium', 'small', 'thumbnail', 'smallThumbnail'];
                        let bestUrl = null;
                        for (const size of sizes) {
                            if (info.imageLinks[size]) {
                                bestUrl = info.imageLinks[size].replace("http://", "https://");
                                break;
                            }
                        }
                        if (bestUrl) fillIfEmpty('imagenInput', bestUrl);
                    }

                    // C. MAPEO DE AUTOR INTELIGENTE
                    if (info.authors && info.authors.length > 0) {
                        matchInSelect('autorSelect', info.authors[0]);
                    }

                    // D. MAPEO DE CATEGORÍAS (Múltiple)
                    if (info.categories && info.categories.length > 0) {
                        info.categories.forEach(cat => matchInSelect('categoriaSelect', cat, true));
                    }

                    showFeedback("✨ Datos recuperados (Se respetaron los campos ya llenos).", "text-success");
                } else {
                    showFeedback("❌ No se encontró información ni siquiera en búsqueda persistente.", "text-warning");
                }
            } catch (error) {
                console.error("Error AI Search:", error);
                showFeedback("⚠️ Error de conexión con el servicio.", "text-danger");
            } finally {
                btn.disabled = false;
                btnText.innerText = "🪄 Autocompletar";
                btnSpinner.classList.add('d-none');
            }
        });

        // Solo llena si el valor actual es nulo o vacío
        function fillIfEmpty(elementId, value) {
            const el = document.getElementById(elementId);
            if (el && value && (!el.value || el.value.trim() === "")) {
                el.value = value;
            }
        }

        // Intenta encontrar una coincidencia de texto en un select
        function matchInSelect(selectId, searchText, isMultiple = false) {
            const select = document.getElementById(selectId);
            if (!select) return;

            const search = searchText.toLowerCase();
            let found = false;

            for (let i = 0; i < select.options.length; i++) {
                const optText = select.options[i].text.toLowerCase();
                // Coincidencia parcial o total
                if (optText.includes(search) || search.includes(optText)) {
                    if (isMultiple) {
                        select.options[i].selected = true;
                    } else if (!found) { // Para select simple, solo el primero que coincida
                        select.selectedIndex = i;
                        found = true;
                    }
                }
            }
        }

        function showFeedback(message, cssClass) {
            const feedback = document.getElementById('isbnFeedback');
            feedback.innerText = message;
            feedback.className = `small mt-1 px-2 ${cssClass}`;
            feedback.classList.remove('d-none');
        }
    </script>
}
