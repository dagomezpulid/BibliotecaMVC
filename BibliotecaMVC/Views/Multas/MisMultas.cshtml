@model IEnumerable<BibliotecaMVC.Models.Multa>

@{
    ViewData["Title"] = "Mis Multas";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">💰 Mis Multas</h2>
    <div>
        <a class="btn btn-outline-secondary shadow-sm" asp-controller="Libros" asp-action="Index">
            🏠 Volver
        </a>
    </div>
</div>

<div class="table-responsive card p-2 rounded-4 shadow-sm border-0 bg-transparent">
    <table class="table table-hover align-middle mb-0 mt-2">
        <thead class="bg-primary bg-opacity-10">
            <tr>
                <th class="border-0 ps-3 text-primary">Libro Asociado</th>
                <th class="border-0 text-center text-primary">Fecha Emisión</th>
                <th class="border-0 text-center text-primary">Monto a Pagar</th>
                <th class="border-0 text-center text-primary">Estado</th>
                <th class="border-0 text-center text-primary">Gestión</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any()) {
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-2">📖</span>
                                <div class="fw-bold text-dark">@(m.Prestamo?.Libro?.Titulo ?? "Sin Título")</div>
                            </div>
                        </td>
                        <td class="text-muted text-center">@m.FechaGenerada.ToShortDateString()</td>
                        <td class="text-center">
                            <span class="text-danger fw-bold fs-5">$@m.Monto.ToString("N0")</span>
                        </td>

                        <td class="text-center">
                            @if (m.Pagada)
                            {
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success px-3 py-2">
                                    <i class="bi bi-check-circle-fill me-1"></i> Saldada
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2">
                                    <i class="bi bi-exclamation-circle-fill me-1"></i> Pendiente
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            @if (!m.Pagada)
                            {
                                <a asp-action="Checkout" asp-route-id="@m.Id" class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm fw-bold">
                                    💳 Pagar Ahora
                                </a>
                            }
                            else
                            {
                                <div class="small text-muted">
                                    <i class="bi bi-calendar-check me-1"></i> Pagado el @m.FechaPago?.ToShortDateString()
                                </div>
                            }
                        </td>
                    </tr>
                }
            } else {
                 <tr>
                    <td colspan="5" class="text-center text-muted py-5">
                        <i class="bi bi-check-all d-block fs-1 mb-2 text-success opacity-50"></i>
                        ¡Felicidades! No tienes multas pendientes.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>