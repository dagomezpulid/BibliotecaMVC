@model IEnumerable<BibliotecaMVC.Models.Multa>

@{
    ViewData["Title"] = "Mis Multas";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">💰 Mis Multas</h2>
    <div>
        <a class="btn btn-outline-secondary shadow-sm" asp-controller="Home" asp-action="Index">
            🏠 Volver
        </a>
    </div>
</div>

<div class="table-responsive bg-white p-3 rounded-4 shadow-sm border-0">

    <table class="table table-hover align-middle mb-0 mt-3">
        <thead class="table-light">
            <tr>
                <th class="border-0">Libro Asociado</th>
                <th class="border-0 text-center">Fecha de Emisión</th>
                <th class="border-0 text-center">Monto a Pagar</th>
                <th class="border-0 text-center">Estado de Deuda</th>
                <th class="border-0 text-center">Acción</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any()) {
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="fw-semibold text-dark">@m.Prestamo.Libro.Titulo</td>
                        <td class="text-muted text-center">@m.FechaGenerada.ToShortDateString()</td>
                        <td class="text-danger fw-bold text-center fs-5">$@m.Monto.ToString("N0")</td>

                        <td class="text-center">
                            @if (m.Pagada)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success fs-6 px-3 py-2">
                                    Saldada
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger fs-6 px-3 py-2">
                                    Pendiente
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            @if (!m.Pagada)
                            {
                                <a asp-action="Checkout" asp-route-id="@m.Id" class="btn btn-sm btn-primary fw-bold shadow-sm rounded-pill px-3">
                                    💳 Pagar
                                </a>
                            }
                            else
                            {
                                <span class="text-muted fst-italic fs-6">Pagado el @m.FechaPago?.ToShortDateString()</span>
                            }
                        </td>
                    </tr>
                }
            } else {
                 <tr>
                    <td colspan="5" class="text-center text-muted py-4">¡Felicidades! No tienes multas pendientes.</td>
                </tr>
            }
        </tbody>
    </table>
</div>