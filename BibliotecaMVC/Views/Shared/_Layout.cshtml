@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BibliotecaMVC</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class ="d-flex flex-column min-vh-100">
    @Html.AntiForgeryToken()

    <header>
        <nav class="navbar navbar-expand-sm navbar-light shadow-sm mb-3 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Libros" asp-action="Index">
                    <span class="fs-3 me-2">📚</span> <span>Biblioteca<span class="text-primary">MVC</span></span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            @* El Catalogo es el Home, ya esta en el Brand Logo *@
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Usuario"))
                            {
                                <li class="nav-item"><a class="nav-link px-3" asp-controller="Prestamos" asp-action="Index">Mis Préstamos</a></li>
                                <li class="nav-item"><a class="nav-link px-3" asp-controller="Favoritos" asp-action="Index">Favoritos ❤️</a></li>
                                <li class="nav-item"><a class="nav-link px-3" asp-controller="Multas" asp-action="MisMultas">Mis Multas</a></li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link px-3 fw-semibold text-primary" asp-controller="Admin" asp-action="Index">Panel Admin</a></li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @* -- Modo Oscuro Toggle -- *@
                        <div class="theme-toggle-btn" id="themeToggle" title="Cambiar tema">
                            <span id="themeIcon">🌓</span>
                        </div>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @* -- Centro de Notificaciones -- *@
                            <div class="dropdown me-2">
                                <a class="nav-link position-relative theme-toggle-btn dropdown-toggle no-caret" href="#" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    🔔
                                    <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" style="font-size: 0.6rem;">
                                        0
                                    </span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end p-0 rounded-4 shadow-lg border-0" aria-labelledby="notifDropdown">
                                    <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light rounded-top-4">
                                        <h6 class="mb-0 fw-bold">Notificaciones</h6>
                                        <span class="badge bg-primary rounded-pill small" id="notifCountText">0 nuevas</span>
                                    </div>
                                    <div id="notifList" class="notif-scroll">
                                        <div class="p-4 text-center text-muted">
                                            <small>Cargando notificaciones...</small>
                                        </div>
                                    </div>
                                    <div class="p-2 text-center border-top">
                                        <small class="text-muted">Centro de Alertas Biblioteca</small>
                                    </div>
                                </div>
                            </div>
                        }

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-fill">
        <main role="main" class="pb-3">
            <div class="container mt-3">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 bg-success bg-opacity-10 text-success">
                        <span class="me-2">✅</span> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 bg-danger bg-opacity-10 text-danger">
                        <span class="me-2">⚠️</span> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
            </div>

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-4 bg-light bg-opacity-50">
        <div class="container text-center">
            &copy; 2026 - <span class="fw-bold text-dark">BibliotecaMVC</span> - Phase 3 Operación Pro
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // --- GESTIÓN DE TEMA (DARK MODE) ---
        const html = document.documentElement;
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        const savedTheme = localStorage.getItem('theme') || 'light';
        setTheme(savedTheme);

        themeToggle.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            setTheme(newTheme);
        });

        function setTheme(theme) {
            html.setAttribute('data-bs-theme', theme);
            localStorage.setItem('theme', theme);
            themeIcon.textContent = theme === 'dark' ? '☀️' : '🌙';
            // Disparar evento para que las gráficas y otros componentes se enteren
            window.dispatchEvent(new Event('themeChanged'));
        }

        // --- GESTIÓN DE NOTIFICACIONES ---
        @if (User.Identity?.IsAuthenticated == true)
        {
            <text>
            async function updateNotifications() {
                try {
                    const res = await fetch('/Notificaciones/GetRecientes');
                    const data = await res.json();
                    
                    const list = document.getElementById('notifList');
                    const badge = document.getElementById('notifBadge');
                    const countText = document.getElementById('notifCountText');

                    if (data.length === 0) {
                        list.innerHTML = '<div class="p-4 text-center text-muted"><small>No tienes notificaciones</small></div>';
                        badge.classList.add('d-none');
                        countText.textContent = "0 nuevas";
                        return;
                    }

                    const unreadCount = data.filter(n => !n.leida).length;
                    if(unreadCount > 0) {
                        badge.textContent = unreadCount;
                        badge.classList.remove('d-none');
                    } else {
                        badge.classList.add('d-none');
                    }
                    countText.textContent = `${unreadCount} nuevas`;

                    list.innerHTML = data.map(n => `
                        <div class="notif-item p-3 ${n.leida ? '' : 'unread'}" onclick="markAsRead(${n.id})">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="fw-bold small">${n.titulo}</span>
                                <small class="text-muted" style="font-size: 0.7rem;">${new Date(n.fechaCreacion).toLocaleTimeString()}</small>
                            </div>
                            <p class="mb-0 small text-muted text-truncate">${n.contenido}</p>
                        </div>
                    `).join('');

                } catch (e) { console.error("Error notif:", e); }
            }

            async function markAsRead(id) {
                // Obtiene el token de seguridad inyectado por @Html.AntiForgeryToken()
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                
                await fetch(`/Notificaciones/MarcarLeida?id=${id}`, { 
                    method: 'POST',
                    headers: {
                        // El header debe coincidir con la expectativa del servidor endurecido
                        'RequestVerificationToken': token
                    }
                });
                updateNotifications();
            }

            // Polling suave cada 60 segundos
            updateNotifications();
            setInterval(updateNotifications, 60000);
            </text>
        }

        // Auto-hide alert
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(a => {
                const bsAlert = new bootstrap.Alert(a);
                bsAlert.close();
            });
        }, 5000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
