@model IEnumerable<BibliotecaMVC.Models.Autor>

@{
    ViewData["Title"] = "Autores";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark">✍ Autores Registrados</h2>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-outline-secondary shadow-sm" asp-controller="Admin" asp-action="Index">
                📊 Volver al Dashboard
            </a>
        }
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center shadow-sm">
            <span class="fs-5 me-2">➕</span> Nuevo Autor
        </a>
    </div>
</div>

<div class="table-responsive card p-2 rounded-4 shadow-sm border-0 bg-white">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
            <tr>
                <th class="border-0 ps-3" style="width: 100px;">ID</th>
                <th class="border-0">Escritor / Autor</th>
                <th class="border-0 text-center">Registrado</th>
                <th class="border-0 text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 fw-bold text-muted">#@item.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-dark bg-opacity-10 text-dark rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                    <span class="fw-bold">@item.Nombre.Substring(0, 1).ToUpper()</span>
                                </div>
                                <div class="fw-semibold text-dark fs-5">@item.Nombre</div>
                            </div>
                        </td>
                        <td class="text-center text-muted small">
                            <i class="bi bi-calendar3 me-1"></i> Vigente
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border-end py-2 px-3">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light py-2 px-3 text-danger">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-5">
                        <i class="bi bi-person-lines-fill d-block fs-1 mb-2 opacity-25"></i>
                        No hay autores registrados en el sistema.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
