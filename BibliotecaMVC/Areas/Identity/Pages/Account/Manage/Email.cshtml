@page
@model EmailModel
@{
    ViewData["Title"] = "Gestión de Correo";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-9">
        <form id="email-form" method="post">
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>
            @if (Model.IsEmailConfirmed)
            {
                <div class="form-floating mb-3 input-group">
                    <input asp-for="Email" class="form-control bg-light" placeholder="Correo actual" disabled />
                        <div class="input-group-append">
                            <span class="h-100 input-group-text text-success font-weight-bold">✓ Confirmado</span>
                        </div>
                    <label asp-for="Email" class="form-label text-muted">Correo Vinculado</label>
                </div>
            }
            else
            {
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control bg-light" placeholder="Correo actual" disabled />
                    <label asp-for="Email" class="form-label text-muted">Correo Pendiente</label>
                    <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail" class="btn btn-link px-0 text-decoration-none fw-bold">📧 Enviar correo de verificación</button>
                </div>
            }
            <div class="form-floating mb-4">
                <input asp-for="Input.NewEmail" class="form-control" autocomplete="email" aria-required="true" placeholder="Nuevo correo" />
                <label asp-for="Input.NewEmail" class="form-label">Nuevo Correo Electrónico</label>
                <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
            </div>
            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="w-100 btn btn-lg btn-primary fw-bold shadow-sm rounded-pill pt-2 pb-2">
                🔄 Actualizar Correo
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
