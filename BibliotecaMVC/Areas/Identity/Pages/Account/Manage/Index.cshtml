@page
@model IndexModel
@{
    ViewData["Title"] = "Datos del Perfil";
    ViewData["ActivePage"] = ManageNavPages.Index;
}


<div class="row">
    <div class="col-md-10">
        @if (Model.EstaBloqueado)
        {
            <div class="alert alert-danger shadow-sm rounded-3 fw-bold mb-4 border-danger">
                ⛔ Tu cuenta se encuentra SUSPENDIDA por morosidad. No puedes realizar nuevos préstamos.
            </div>
        }
        else
        {
            <div class="alert alert-success shadow-sm rounded-3 fw-bold mb-4 border-success">
                ✅ Tu cuenta está AL DÍA y habilitada para la biblioteca.
            </div>
        }

        <div class="card shadow-sm border-0 bg-light rounded-4">
            <div class="card-body p-4">
                
                <div class="mb-3">
                    <label class="text-muted small fw-bold mb-1">IDENTIFICADOR DE ACCESO (EMAIL)</label>
                    <input class="form-control bg-white fw-semibold" value="@Model.Username" disabled />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small fw-bold mb-1">NOMBRE COMPLETO</label>
                        <input class="form-control bg-white fw-semibold" value="@Model.NombreCompleto" disabled />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small fw-bold mb-1">TELÉFONO MÓVIL</label>
                        <input class="form-control bg-white fw-semibold" value="@Model.Telefono" disabled />
                    </div>
                </div>

                <div class="text-muted text-center mt-3 pt-3 border-top small">
                    <i>Los datos mostrados aquí son de solo lectura. Para modificarlos, utiliza el menú lateral.</i>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
