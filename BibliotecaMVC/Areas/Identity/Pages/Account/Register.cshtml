@page
@model BibliotecaMVC.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Crear Cuenta";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5 mt-4">
        <div class="card shadow rounded-4 border-0">
            <div class="card-header bg-info text-white rounded-top-4 py-3">
                <h4 class="mb-0 fw-bold text-center">📝 Crear Cuenta</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                
                <p class="text-muted text-center mb-4">Únete a la Biblioteca Digital y accede a miles de lecturas.</p>

                <form method="post" id="registerForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="Input.Nombre" class="form-control" placeholder="Nombre" />
                                <label asp-for="Input.Nombre">Nombre</label>
                                <span asp-validation-for="Input.Nombre" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="Input.Apellido" class="form-control" placeholder="Apellido" />
                                <label asp-for="Input.Apellido">Apellido</label>
                                <span asp-validation-for="Input.Apellido" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Ej: 3001234567" />
                        <label asp-for="Input.PhoneNumber">Teléfono Móvil (WhatsApp)</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="correo@ejemplo.com" />
                        <label asp-for="Input.Email">Correo Electrónico</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input asp-for="Input.Password" class="form-control pe-5" autocomplete="new-password" placeholder="Contraseña" id="Input_Password" />
                        <label asp-for="Input.Password">Contraseña</label>
                        <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-1 toggle-password" data-target="Input_Password" style="z-index: 5; background: none; border: none;" title="Mostrar Contraseña">
                            👁️
                        </button>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 px-1">
                        <div class="progress" style="height: 5px;">
                            <div id="password-strength-bar" class="progress-bar bg-danger" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small id="password-strength-text" class="form-text text-muted fw-bold" style="font-size: 0.75rem;">Nivel de seguridad</small>
                    </div>

                    <div class="form-floating mb-4 position-relative">
                        <input asp-for="Input.ConfirmPassword" class="form-control pe-5" autocomplete="new-password" placeholder="Confirmar contraseña" id="Input_ConfirmPassword" />
                        <label asp-for="Input.ConfirmPassword">Confirmar Contraseña</label>
                        <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-1 toggle-password" data-target="Input_ConfirmPassword" style="z-index: 5; background: none; border: none;" title="Mostrar Contraseña">
                            👁️
                        </button>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button id="registerSubmit" type="submit" class="btn btn-info text-white btn-lg fw-bold shadow-sm rounded-pill mt-2">
                            Registrarse
                        </button>
                    </div>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="text-muted mb-1">¿Ya tienes una cuenta?</p>
                        <a asp-page="./Login" class="text-info fw-bold text-decoration-none h5">
                            Inicia Sesión aquí
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Toggle de contraseña
        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', function() {
                const targetId = this.getAttribute('data-target');
                const input = document.getElementById(targetId);
                if (input.type === 'password') {
                    input.type = 'text';
                    this.textContent = '👀';
                } else {
                    input.type = 'password';
                    this.textContent = '👁️';
                }
            });
        });

        // Medidor de seguridad de contraseña
        const passwordInput = document.getElementById('Input_Password');
        const strengthBar = document.getElementById('password-strength-bar');
        const strengthText = document.getElementById('password-strength-text');

        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                const val = passwordInput.value;
                let score = 0;
                
                if (val.length >= 8) score += 25;
                if (/[A-Z]/.test(val)) score += 25;
                if (/[a-z]/.test(val)) score += 25;
                if (/[0-9]/.test(val)) score += 25;

                strengthBar.style.width = score + '%';
                
                if (val.length === 0) {
                    strengthBar.style.width = '0%';
                    strengthText.textContent = 'Nivel de seguridad';
                    strengthBar.className = 'progress-bar bg-danger';
                } else if (score < 50) {
                    strengthBar.className = 'progress-bar bg-danger';
                    strengthText.className = 'form-text text-danger fw-bold';
                    strengthText.textContent = 'Débil. Faltan caracteres (min. 8) y combinaciones.';
                } else if (score < 100) {
                    strengthBar.className = 'progress-bar bg-warning';
                    strengthText.className = 'form-text text-warning fw-bold';
                    strengthText.textContent = 'Buena. Faltan requisitos (mayúscula, minúscula, o número).';
                } else {
                    strengthBar.className = 'progress-bar bg-success';
                    strengthText.className = 'form-text text-success fw-bold';
                    strengthText.textContent = 'Fuerte y segura ✅';
                }
            });
        }

        // Validación en tiempo real (keyup)
        $('form#registerForm input').on('keyup blur', function () {
            $(this).valid(); // Fuerza la validación de jQuery al instante
        });
    </script>
}
